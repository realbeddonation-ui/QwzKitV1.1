function K.startRecording()
	if Macro.sampleConn then
		Macro.sampleConn:Disconnect()
		Macro.sampleConn = nil
	end
	Macro.recordBuffer = {}
	Macro.recordStart = os.clock()
	Macro.recording = true
	local lastSampleT = -1
	local lastSent = Vector3.zero
	-- Many games drive movement without Humanoid.MoveDirection; WASD matches what the client actually holds.
	local function keyboardWalkOnXZ()
		local cam = Workspace.CurrentCamera
		if not cam then
			return Vector3.zero
		end
		local look = cam.CFrame.LookVector
		local right = cam.CFrame.RightVector
		local lz = Vector3.new(look.X, 0, look.Z)
		local rx = Vector3.new(right.X, 0, right.Z)
		if lz.Magnitude < 0.001 then
			return Vector3.zero
		end
		lz = lz.Unit
		if rx.Magnitude < 0.001 then
			rx = Vector3.xAxis
		else
			rx = rx.Unit
		end
		local m = Vector3.zero
		if UserInputService:IsKeyDown(Enum.KeyCode.W) then
			m += lz
		end
		if UserInputService:IsKeyDown(Enum.KeyCode.S) then
			m -= lz
		end
		if UserInputService:IsKeyDown(Enum.KeyCode.D) then
			m += rx
		end
		if UserInputService:IsKeyDown(Enum.KeyCode.A) then
			m -= rx
		end
		if m.Magnitude < 0.02 then
			return Vector3.zero
		end
		return m.Unit
	end
	Macro.sampleConn = RunService.Heartbeat:Connect(function()
		if not Macro.recording or not Macro.recordStart then
			return
		end
		local t = os.clock() - Macro.recordStart
		if t - lastSampleT < 0.04 then
			return
		end
		lastSampleT = t
		local h = K.getHumanoid()
		if not h then
			return
		end
		local keyFlat = keyboardWalkOnXZ()
		local humFlat = Vector3.new(h.MoveDirection.X, 0, h.MoveDirection.Z)
		local dFlat = keyFlat.Magnitude > 0.08 and keyFlat or humFlat
		if dFlat.Magnitude < 0.035 then
			if lastSent.Magnitude > 0.02 then
				table.insert(Macro.recordBuffer, {
					t = t,
					action = "movedir",
					x = 0,
					y = 0,
					z = 0,
				})
				lastSent = Vector3.zero
			end
			return
		end
		dFlat = dFlat.Unit
		if (dFlat - lastSent).Magnitude < 0.08 and lastSent.Magnitude > 0.1 then
			return
		end
		lastSent = dFlat
		table.insert(Macro.recordBuffer, {
			t = t,
			action = "movedir",
			x = dFlat.X,
			y = 0,
			z = dFlat.Z,
		})
	end)
end

function K.stopRecording(saveName)
	if Macro.sampleConn then
		Macro.sampleConn:Disconnect()
		Macro.sampleConn = nil
	end
	if not Macro.recording then
		return false
	end
	Macro.recording = false
	if #Macro.recordBuffer == 0 then
		Macro.recordStart = nil
		return false
	end
	local saved = Macro.recordBuffer
    local mac = {
		name = saveName or ("Macro " .. tostring(#Macro.list + 1)),
        hotkey = nil,
		inputs = saved,
        on = true,
    }
	table.insert(Macro.list, mac)
	Macro.recordBuffer = {}
	Macro.recordStart = nil
	return true
end

function K.recordInput(action)
	if not Macro.recording or not Macro.recordStart then
		return
	end
	table.insert(Macro.recordBuffer, {
		t = os.clock() - Macro.recordStart,
        action = action,
    })
end

-- Returns true if the key was consumed (hotkey assign or macro playback).
function K.handleMacroKeyboardInput(input)
	if input.UserInputType ~= Enum.UserInputType.Keyboard then
		return false
	end
	if K.getFocusedTextBox() then
		return false
	end
	if Macro.hotkeyListen and Macro.hotkeyListenIndex then
		local mac = Macro.list[Macro.hotkeyListenIndex]
		if mac and input.KeyCode ~= Enum.KeyCode.Escape then
                    mac.hotkey = input.KeyCode
                end
		Macro.hotkeyListen = false
		Macro.hotkeyListenIndex = nil
		if Macro.listFrame then
                K.rebuildMacroList()
            end
		return true
	end
	if Macro.recording then
		return false
	end
	for idx, mac in ipairs(Macro.list) do
            if mac.on and mac.hotkey and input.KeyCode == mac.hotkey then
                K.playMacro(idx)
			return true
            end
        end
	return false
end

function CC.getHrpForUserId(uid)
	if uid == nil or uid == me.UserId then
		local c = me.Character
		return c and c:FindFirstChild("HumanoidRootPart")
	end
	for _, plr in ipairs(Players:GetPlayers()) do
		if plr.UserId == uid and plr.Character then
			return plr.Character:FindFirstChild("HumanoidRootPart")
		end
	end
	return nil
end

