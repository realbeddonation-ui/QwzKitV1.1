function K.hookToolRecording(char)
	for _, child in char:GetChildren() do
		if child:IsA("Tool") then
			child.Activated:Connect(function() K.recordInput("toolactivate") end)
			child.Deactivated:Connect(function() K.recordInput("tooldeactivate") end)
		end
	end
	char.ChildAdded:Connect(function(child)
		if child:IsA("Tool") then
			child.Activated:Connect(function() K.recordInput("toolactivate") end)
			child.Deactivated:Connect(function() K.recordInput("tooldeactivate") end)
		end
	end)
end

if me.Character then K.hookToolRecording(me.Character) end
