function K.animPassesPathFilter(inst)
	if not animScanR6PathOnly or animPathFilterText == "" then
		return true
	end
	local path = inst:GetFullName()
	return string.find(path, animPathFilterText, 1, true) ~= nil
end

function K.scanAnimationsIntoResults()
	table.clear(animScanResults)
	local seen = {}
	local roots = K.animScanRoots()
	for _, root in ipairs(roots) do
		pcall(function()
			for _, d in root:GetDescendants() do
				if d:IsA("Animation") and d.AnimationId ~= "" and K.animPassesPathFilter(d) then
					if not seen[d] then
						seen[d] = true
						table.insert(animScanResults, d)
					end
				end
			end
		end)
	end
	for _, plr in ipairs(Players:GetPlayers()) do
		pcall(function()
			if plr.Character then
				for _, d in plr.Character:GetDescendants() do
					if d:IsA("Animation") and d.AnimationId ~= "" and K.animPassesPathFilter(d) then
						if not seen[d] then
							seen[d] = true
							table.insert(animScanResults, d)
						end
					end
				end
			end
		end)
	end
end

