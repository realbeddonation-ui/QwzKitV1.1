function K.targetKitSteerDir(from, goalPos, char, useAvoid)
	local delta = goalPos - from
	if delta.Magnitude < 0.2 then
		return Vector3.zero
	end
	local want = delta.Unit
	if not useAvoid or not char then
		return want
	end
	local params = RaycastParams.new()
	params.FilterType = Enum.RaycastFilterType.Blacklist
	params.FilterDescendantsInstances = { char }
	params.IgnoreWater = true
	local origin = from + Vector3.new(0, 1.25, 0)
	local probe = 8
	local function rayClear(dir)
		local u = dir.Unit
		local hit = Workspace:Raycast(origin, u * probe, params)
		return hit == nil
	end
	if rayClear(want) then
		return want
	end
	local up = Vector3.yAxis
	local right = want:Cross(up)
	if right.Magnitude < 0.06 then
		right = want:Cross(Vector3.new(1, 0, 0))
	end
	right = right.Unit
	local best = want
	local bestDot = -2
	local function tryDir(d)
		if d.Magnitude < 0.05 then
			return
		end
		d = d.Unit
		if rayClear(d) then
			local dot = d:Dot(want)
			if dot > bestDot then
				bestDot = dot
				best = d
			end
		end
	end
	for _, deg in ipairs({ 22, -22, 45, -45, 68, -68, 90, -90, 115, -115 }) do
		tryDir(CFrame.fromAxisAngle(up, math.rad(deg)):VectorToWorldSpace(want))
	end
	for _, deg in ipairs({ 18, -18, 35, -35, 55, -55 }) do
		tryDir(CFrame.fromAxisAngle(right, math.rad(deg)):VectorToWorldSpace(want))
	end
	tryDir(up)
	tryDir(-up)
	tryDir((want + up * 0.65).Unit)
	tryDir((want - up * 0.65).Unit)
	tryDir((want + right * 0.55).Unit)
	tryDir((want - right * 0.55).Unit)
	return best
end

function K.targetKitHorizontalBlocked(from, goalPos, char, yLift, probeDist)
	local flat = Vector3.new(goalPos.X - from.X, 0, goalPos.Z - from.Z)
	local m = flat.Magnitude
	if m < 0.08 then
		return false
	end
	local dir = flat.Unit
	local dist = math.clamp(probeDist or m, 5, 85)
	local params = RaycastParams.new()
	params.FilterType = Enum.RaycastFilterType.Blacklist
	params.FilterDescendantsInstances = { char }
	params.IgnoreWater = true
	local origin = Vector3.new(from.X, from.Y + (yLift or 1.25), from.Z)
	return Workspace:Raycast(origin, dir * dist, params) ~= nil
end

