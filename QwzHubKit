function K.setOpAimLineFrame(frame, x1, y1, x2, y2)
	local dx = x2 - x1
	local dy = y2 - y1
	local len = math.sqrt(dx * dx + dy * dy)
	if len < 1 then
		frame.Visible = false
		return
	end
	local midX = (x1 + x2) / 2
	local midY = (y1 + y2) / 2
	frame.Visible = true
	frame.Position = UDim2.fromOffset(midX, midY)
	frame.Rotation = math.deg(math.atan2(dy, dx))
	frame.Size = UDim2.fromOffset(len, ESP.opAimLineThickness)
	frame.BackgroundTransparency = math.clamp(1 - ESP.opAimLineAlpha, 0, 1)
end

function K.opCombatHeartbeat()
	local plr = K.getOpCombatTargetPlayer()
	if not plr or not plr.Character then
		if ESP.opAimLineFrame then
			ESP.opAimLineFrame.Visible = false
		end
	end

	local head = plr and K.getHead(plr) or nil
	local myRoot = K.getRoot()
	local cam = K.getCam()
	local hum = K.getHumanoid()

	-- Face-lock rotation runs in cameraLockStep (same frame, late priority) when camera lock is on; avoids fighting the scriptable camera and reduces shake.

	if ESP.opSpinOn and myRoot and not ESP.opCameraLockOn then
		local cf = myRoot.CFrame
		local yaw = math.rad(ESP.opSpinSpeed / 60)
		myRoot.CFrame = cf * CFrame.Angles(0, yaw, 0)
	end

	if ESP.opBhopOn and hum and hum.Health > 0 then
		local st = hum:GetState()
		if st ~= Enum.HumanoidStateType.Freefall and st ~= Enum.HumanoidStateType.Jumping then
			hum:ChangeState(Enum.HumanoidStateType.Jumping)
		end
	end

	if ESP.opAimLineOn and cam and head then
		local fr = ESP.opAimLineFrame or K.ensureOpAimLineFrame()
		if fr and fr.Parent then
			local vp, inFront = cam:WorldToViewportPoint(head.Position)
			if inFront then
				local viewport = cam.ViewportSize
				local ox, oy = viewport.X / 2, viewport.Y / 2
				K.setOpAimLineFrame(fr, ox, oy, vp.X, vp.Y)
				if plr.Team and plr.Team.TeamColor then
					fr.BackgroundColor3 = plr.Team.TeamColor.Color
				else
					fr.BackgroundColor3 = COL.accent
				end
			else
				fr.Visible = false
			end
		end
	elseif ESP.opAimLineFrame then
		ESP.opAimLineFrame.Visible = false
	end
end

function K.stopCameraLock()
