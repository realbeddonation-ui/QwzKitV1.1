function K.toggleMenuKey(input)
	return input.KeyCode == Enum.KeyCode.Minus or input.KeyCode == Enum.KeyCode.KeypadMinus
end

UserInputService.InputBegan:Connect(function(input, gameUsedIt)
	if Macro.recording and input.UserInputType == Enum.UserInputType.MouseButton1 then
		if not K.getFocusedTextBox() and panel and panel.Visible then
			local p = UserInputService:GetMouseLocation()
			local hit = GuiService:GetGuiObjectsAtPosition(p.X, p.Y)
			local overKit = false
			for _, o in ipairs(hit) do
				if o:IsDescendantOf(panel) then
					overKit = true
					break
				end
			end
			if not overKit then
				K.recordInput("mclick")
			end
		elseif not K.getFocusedTextBox() and panel and not panel.Visible then
			K.recordInput("mclick")
		end
	end
	if input.UserInputType ~= Enum.UserInputType.Keyboard then
		return
	end
	if Macro.recording and input.KeyCode == Enum.KeyCode.Space then
		K.recordInput("jump")
	end
	if Macro.recording then
		if input.KeyCode == Enum.KeyCode.One then
			K.recordInput("key1")
		elseif input.KeyCode == Enum.KeyCode.Two then
			K.recordInput("key2")
		elseif input.KeyCode == Enum.KeyCode.Three then
			K.recordInput("key3")
		elseif input.KeyCode == Enum.KeyCode.Four then
			K.recordInput("key4")
		elseif input.KeyCode == Enum.KeyCode.Five then
			K.recordInput("key5")
		elseif input.KeyCode == Enum.KeyCode.Six then
			K.recordInput("key6")
		elseif input.KeyCode == Enum.KeyCode.Seven then
			K.recordInput("key7")
		elseif input.KeyCode == Enum.KeyCode.Eight then
			K.recordInput("key8")
		elseif input.KeyCode == Enum.KeyCode.Nine then
			K.recordInput("key9")
		end
	end
	if K.handleMacroKeyboardInput(input) then
		return
	end
	if not K.getFocusedTextBox() then
	if CC.slideKeyListenMode then
		if input.KeyCode == Enum.KeyCode.Escape then
			CC.slideKeyListenMode = false
		elseif CC.slideKeyListenMode == "run" and input.KeyCode ~= Enum.KeyCode.Unknown then
			CC.slideRunKey = input.KeyCode
			CC.slideKeyListenMode = false
		elseif CC.slideKeyListenMode == "stop" and input.KeyCode ~= Enum.KeyCode.Unknown then
			CC.slideStopKey = input.KeyCode
			CC.slideKeyListenMode = false
		end
		return
	end
	end
	if not K.getFocusedTextBox() then
	if CC.slideRunKey ~= Enum.KeyCode.Unknown and input.KeyCode == CC.slideRunKey then
		CC.runAnimSlide()
		return
	end
	if CC.slideStopKey ~= Enum.KeyCode.Unknown and input.KeyCode == CC.slideStopKey then
		CC.stopAnimSlide()
		return
	end
	end
	if flyKeybindListen then
		flyKeybindListen = false
		if input.KeyCode ~= Enum.KeyCode.Escape and input.KeyCode ~= Enum.KeyCode.Unknown then
			flyToggleKey = input.KeyCode
		end
		K.refreshMoveLabels()
		return
	end
	if ESP.opFaceKeyListen then
		ESP.opFaceKeyListen = false
		if input.KeyCode ~= Enum.KeyCode.Escape and input.KeyCode ~= Enum.KeyCode.Unknown then
			ESP.opFaceLockKey = input.KeyCode
		end
		K.refreshOpCombatUi()
		return
	end
	if K.getFocusedTextBox() then
		return
	end
	if gameUsedIt then
		return
	end
	if K.toggleMenuKey(input) then
		panel.Visible = not panel.Visible
		return
	end
	if input.KeyCode == flyToggleKey then
		flyOn = not flyOn
		K.setFlyRunning()
		K.refreshMoveLabels()
		return
	end
	if input.KeyCode == ESP.opFaceLockKey then
		ESP.opFaceLockOn = not ESP.opFaceLockOn
		K.setOpCombatRunning()
	end
end)

