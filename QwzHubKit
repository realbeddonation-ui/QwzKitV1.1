local K = {}
-- ========= Small utils =========
function K.getRoot()
	local char = me.Character
	if not char then
		return nil
	end
	return char:FindFirstChild("HumanoidRootPart")
end

function K.getHumanoid()
	local char = me.Character
	if not char then
		return nil
	end
	return char:FindFirstChildOfClass("Humanoid")
end

function K.getCam()
	return Workspace.CurrentCamera
end


-- ========= Anti-TP (original logic) =========
function K.snapLimit()
	local n = snapStuds
	if strongMode then
		n = math.max(3, n * 0.55)
	end
	return n
end

function K.moveLooksNormal(move, limit)
	local flat = Vector3.new(move.X, 0, move.Z).Magnitude
	local up = math.abs(move.Y)
	local len = move.Magnitude
	if len < limit then
		return true
	end
	if jumpsCount and flat < limit * 0.65 and up <= maxJumpStuds then
		return true
	end
	return false
end

function K.hasMoveIntent(humanoid)
	if UserInputService:IsKeyDown(Enum.KeyCode.W) or UserInputService:IsKeyDown(Enum.KeyCode.Up) then
		return true
	end
	if UserInputService:IsKeyDown(Enum.KeyCode.S) or UserInputService:IsKeyDown(Enum.KeyCode.Down) then
		return true
	end
	if UserInputService:IsKeyDown(Enum.KeyCode.A) or UserInputService:IsKeyDown(Enum.KeyCode.Left) then
		return true
	end
	if UserInputService:IsKeyDown(Enum.KeyCode.D) or UserInputService:IsKeyDown(Enum.KeyCode.Right) then
		return true
	end
	if flyOn and (UserInputService:IsKeyDown(Enum.KeyCode.Space) or UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) or UserInputService:IsKeyDown(Enum.KeyCode.C)) then
		return true
	end
	if humanoid and humanoid.MoveDirection.Magnitude > 0.06 then
		return true
	end
	return false
end

function K.putMeBack(restorePivot)
	local char = me.Character
	local rootPart = K.getRoot()
	local pivot = restorePivot or savedPivot
	if pivot and char and rootPart then
		char:PivotTo(pivot)
		rootPart.AssemblyLinearVelocity = savedSpeed
		rootPart.AssemblyAngularVelocity = Vector3.zero
		antiTpLastUndo = os.clock()
	end
end

function K.shouldUndo(rootPart, humanoid, here, limit)
	if humanoid.Health <= 0 then
		return false
	end
	local movingIntent = K.hasMoveIntent(humanoid)
	if movingIntent and (os.clock() - antiTpLastUndo) < antiTpMoveGrace then
		return false
	end
	local activeLimit = movingIntent and (limit * (flyOn and 2.8 or 2.1)) or limit
	local restorePivot = savedPivot
	local moveLooksBad = false
	if restorePivot then
		local move = here - restorePivot.Position
		moveLooksBad = not K.moveLooksNormal(move, activeLimit)
	end
	if (not moveLooksBad) and savedPivotPrev then
		local movePrev = here - savedPivotPrev.Position
		if not K.moveLooksNormal(movePrev, activeLimit * 0.9) then
			restorePivot = savedPivotPrev
			moveLooksBad = true
		end
	end
	if movingIntent and moveLooksBad and restorePivot then
		local moveNow = here - restorePivot.Position
		if moveNow.Magnitude <= activeLimit * 1.35 then
			return false
		end
	end
	if not moveLooksBad or not restorePivot then
		return false
	end
	K.putMeBack(restorePivot)
	return true
end

function K.saveSpot(rootPart)
	local char = me.Character
	if char then
		savedPivotPrev = savedPivot
		savedPivot = char:GetPivot()
	end
	savedSpeed = rootPart.AssemblyLinearVelocity
end

function K.beforePhysics()
	if not antiTpOn then
		placeBeforePhysics = nil
		return
	end
	local r = K.getRoot()
	if r then
		placeBeforePhysics = r.CFrame
	end
end

function K.afterPhysics()
	local r = K.getRoot()
	local h = K.getHumanoid()

	if not antiTpOn then
		if r then
			K.saveSpot(r)
		end
		return
	end
	if not r or not h or h.Health <= 0 then
		return
	end

	-- Loop TP / orbit strafe / fling move the HRP in ways anti-TP treats as "teleports" — skip undo.
	if loopTpOn or combatStrafeOn or (combatResistOn and combatResistAntiTpBypass) or CC.flingInProgress or ESP.autoForceTpOn or ESP.autoForceTpBurstRunning then
		K.saveSpot(r)
		return
	end

	local limit = K.snapLimit()
	local pos = r.CFrame.Position

	if not savedPivot then
		K.saveSpot(r)
		placeBeforePhysics = nil
		return
	end

	if placeBeforePhysics then
		local jump = (pos - placeBeforePhysics.Position).Magnitude
		if jump >= limit and not K.moveLooksNormal(pos - placeBeforePhysics.Position, limit) then
			K.putMeBack()
			placeBeforePhysics = nil
			return
		end
	end
	placeBeforePhysics = nil

	if K.shouldUndo(r, h, pos, limit) then
		return
	end

	if os.clock() - antiTpLastUndo < antiTpUndoCooldown then
		return
	end

	K.saveSpot(r)
end

function K.hideExtraBodyLocal(model)
	for _, d in model:GetDescendants() do
		if d:IsA("BasePart") then
			d.LocalTransparencyModifier = 1
		elseif d:IsA("Decal") or d:IsA("Texture") then
			d.LocalTransparencyModifier = 1
		end
	end
	extraBodiesHidden[model] = true
end

function K.isExtraCopyOfMe(model)
	if not model:IsA("Model") or model == me.Character then
		return false
	end
	if not model:FindFirstChildOfClass("Humanoid") then
		return false
	end
	if Players:GetPlayerFromCharacter(model) == me then
		return true
	end
	if model.Name ~= me.Name then
		return false
	end
	local myRoot = K.getRoot()
	local theirRoot = model:FindFirstChild("HumanoidRootPart")
	if not myRoot or not theirRoot then
		return false
	end
	return (theirRoot.Position - myRoot.Position).Magnitude > 6
end

function K.scanForExtraBodies()
	if not antiTpOn then
		return
	end
	for _, d in Workspace:GetDescendants() do
		if d:IsA("Model") and K.isExtraCopyOfMe(d) then
			K.hideExtraBodyLocal(d)
		end
	end
end

function K.clearExtraBodyHides()
	for model, _ in pairs(extraBodiesHidden) do
		if model.Parent then
			for _, d in model:GetDescendants() do
				if d:IsA("BasePart") or d:IsA("Decal") or d:IsA("Texture") then
					d.LocalTransparencyModifier = 0
				end
			end
		end
	end
	table.clear(extraBodiesHidden)
end

function K.heartbeatAgain()
	if not antiTpOn then
		return
	end
	if loopTpOn or combatStrafeOn or (combatResistOn and combatResistAntiTpBypass) or CC.flingInProgress or ESP.autoForceTpOn or ESP.autoForceTpBurstRunning then
		return
	end
	if strongMode then
		local r = K.getRoot()
		local h = K.getHumanoid()
		if r and h and h.Health > 0 and savedPivot then
			K.shouldUndo(r, h, r.CFrame.Position, K.snapLimit())
		end
	end
	ESP.dupeScanTick += 1
	if ESP.dupeScanTick % 15 == 0 then
		K.scanForExtraBodies()
	end
end

function K.drawFrameAgain()
	if not antiTpOn or not savedPivot then
		return
	end
	if loopTpOn or combatStrafeOn or (combatResistOn and combatResistAntiTpBypass) or CC.flingInProgress or ESP.autoForceTpOn or ESP.autoForceTpBurstRunning then
		return
	end
	local r = K.getRoot()
	local h = K.getHumanoid()
	if not r or not h or h.Health <= 0 then
		return
	end
	K.shouldUndo(r, h, r.CFrame.Position, K.snapLimit())
end

function K.stopHooks()
	if hookAfterPhysics then
		hookAfterPhysics:Disconnect()
		hookAfterPhysics = nil
	end
	if hookHeartbeat then
		hookHeartbeat:Disconnect()
		hookHeartbeat = nil
	end
	if hookBeforePhysics then
		hookBeforePhysics:Disconnect()
		hookBeforePhysics = nil
	end
	savedPivot = nil
	savedPivotPrev = nil
	placeBeforePhysics = nil
	if duplicateListener then
		duplicateListener:Disconnect()
		duplicateListener = nil
	end
	K.clearExtraBodyHides()
end

function K.stopDrawHook()
	pcall(function()
		RunService:UnbindFromRenderStep(RENDER_NAME)
	end)
end

function K.startHooks()
	K.stopHooks()
	savedPivot = nil
	savedPivotPrev = nil
	if RunService.PreSimulation then
		hookBeforePhysics = RunService.PreSimulation:Connect(K.beforePhysics)
	end
	if RunService.PostSimulation then
		hookAfterPhysics = RunService.PostSimulation:Connect(K.afterPhysics)
	else
		hookAfterPhysics = RunService.Heartbeat:Connect(K.afterPhysics)
	end
	hookHeartbeat = RunService.Heartbeat:Connect(K.heartbeatAgain)
	duplicateListener = Workspace.DescendantAdded:Connect(function(thing)
		if not thing:IsA("Model") then
			return
		end
		task.spawn(function()
			task.wait()
			if antiTpOn and K.isExtraCopyOfMe(thing) then
				K.hideExtraBodyLocal(thing)
			end
		end)
	end)
	task.defer(function()
		if antiTpOn then
			K.scanForExtraBodies()
		end
	end)
end

function K.startDrawHook()
	K.stopDrawHook()
	RunService:BindToRenderStep(RENDER_NAME, RENDER_LAST, K.drawFrameAgain)
end

function K.setAntiTpRunning()
	if antiTpOn then
		K.startHooks()
		K.startDrawHook()
	else
		K.stopHooks()
		K.stopDrawHook()
	end
end

function K.isGlowing(part)
	if part.Material == Enum.Material.Neon or part.Material == Enum.Material.ForceField then
		return true
	end
	for _, kid in part:GetChildren() do
		if kid:IsA("PointLight") or kid:IsA("SurfaceLight") or kid:IsA("SpotLight") then
			return true
		end
	end
	return false
end

function K.bigEnoughGlowy(part)
	if not hideGlow or part:IsA("Terrain") then
		return false
	end
	local char = me.Character
	if char and part:IsDescendantOf(char) then
		return false
	end
	local big = math.max(part.Size.X, part.Size.Y, part.Size.Z)
	if big < minBigPartStuds then
		return false
	end
	return K.isGlowing(part)
end

function K.hidePartForMe(part)
	part.LocalTransparencyModifier = 1
	partsWeHid[part] = true
	for _, kid in part:GetDescendants() do
		if kid:IsA("BasePart") then
			kid.LocalTransparencyModifier = 1
			partsWeHid[kid] = true
		elseif kid:IsA("Decal") or kid:IsA("Texture") then
			kid.LocalTransparencyModifier = 1
		end
	end
end

function K.maybeHide(thing)
	if thing:IsA("BasePart") and K.bigEnoughGlowy(thing) then
		K.hidePartForMe(thing)
	end
end

function K.scanWorld()
	if not hideGlow then
		return
	end
	for _, d in Workspace:GetDescendants() do
		if d:IsA("BasePart") then
			K.maybeHide(d)
		end
	end
end

function K.unhideAll()
	for part, _ in pairs(partsWeHid) do
		if part.Parent then
			part.LocalTransparencyModifier = 0
			for _, kid in part:GetDescendants() do
				if kid:IsA("BasePart") or kid:IsA("Decal") or kid:IsA("Texture") then
					kid.LocalTransparencyModifier = 0
				end
			end
		end
	end
	table.clear(partsWeHid)
end

function K.stopGlowStuff()
	if glowListener then
		glowListener:Disconnect()
		glowListener = nil
	end
	K.unhideAll()
end

