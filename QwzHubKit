function K.parseCsvLower(s)
	local t = {}
	for piece in string.gmatch(s or "", "([^,]+)") do
		piece = string.gsub(piece, "^%s+", "")
		piece = string.gsub(piece, "%s+$", "")
		if piece ~= "" then
			table.insert(t, string.lower(piece))
		end
	end
	if #t == 0 then
		table.insert(t, "hitbox")
	end
	return t
end

function K.hitboxNameMatches(part, patterns)
	local n = string.lower(part.Name)
	for _, p in ipairs(patterns) do
		if string.find(n, p, 1, true) then
			return true
		end
	end
	return false
end

function K.likelyHitboxHeuristic(part)
	if not part:IsA("BasePart") then
		return false
	end
	local myChar = me.Character
	if myChar and part:IsDescendantOf(myChar) then
		return false
	end
	local s = part.Size
	local vol = s.X * s.Y * s.Z
	local nearHumanoid = false
	local p = part.Parent
	local depth = 0
	while p and depth < 5 do
		if p:FindFirstChildOfClass("Humanoid") then
			nearHumanoid = true
			break
		end
		p = p.Parent
		depth += 1
	end
	local invisibleLike = part.Transparency >= 0.7 or part.CanCollide == false
	local plausibleSize = vol > 0.05 and vol < 600
	if not (plausibleSize and (invisibleLike or part.CanTouch == true)) then
		return false
	end
	local score = 0
	if part.Transparency >= 0.85 then
		score += 1
	end
	if part.CanCollide == false then
		score += 1
	end
	if part.CanTouch == true then
		score += 1
	end
	if vol < 80 then
		score += 1
	end
	if nearHumanoid then
		score += 1
	end
	return score >= 2
end

function K.hitboxApplyVisual(part, on)
	if on then
		if hitboxSavedLTM[part] == nil then
			hitboxSavedLTM[part] = part.LocalTransparencyModifier
		end
		part.LocalTransparencyModifier = math.clamp(hitboxVisualLevel, 0, 1)
		local hl = hitboxPartHighlights[part]
		if not hl or not hl.Parent then
			hl = Instance.new("Highlight")
			hl.Name = "TesterHitboxHighlight"
			hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
			hl.OutlineTransparency = 0
			hl.FillTransparency = hitboxVisualLevel
			hl.FillColor = Color3.fromRGB(255, 80, 80)
			hl.OutlineColor = Color3.fromRGB(255, 220, 220)
			hl.Parent = part
			hitboxPartHighlights[part] = hl
		end
		hl.FillTransparency = hitboxVisualLevel
	else
		local prev = hitboxSavedLTM[part]
		if prev ~= nil then
			part.LocalTransparencyModifier = prev
			hitboxSavedLTM[part] = nil
		end
		local hl = hitboxPartHighlights[part]
		if hl then
			pcall(function()
				hl:Destroy()
			end)
			hitboxPartHighlights[part] = nil
		end
	end
end

function K.hitboxProcessPart(inst)
	if not hitboxDebugOn or not inst:IsA("BasePart") then
		return
	end
	if ESP.opHitboxTargetOnlyOn then
		local tPlr = K.getOpCombatTargetPlayer()
		local tChar = tPlr and tPlr.Character
		if not tChar or not inst:IsDescendantOf(tChar) then
			return
		end
	end
	local patterns = hitboxPatternBox and K.parseCsvLower(hitboxPatternBox.Text) or { "hitbox" }
	local namedMatch = K.hitboxNameMatches(inst, patterns)
	local heuristicMatch = K.likelyHitboxHeuristic(inst)
	if not (namedMatch or heuristicMatch) then
		return
	end
	if hitboxLogOn then
		print("[TesterToolkit] Hitbox-ish part:", inst:GetFullName(), "size", inst.Size)
	end
	if hitboxVisualOn then
		K.hitboxApplyVisual(inst, true)
	end
end

function K.hitboxRescanWorld()
