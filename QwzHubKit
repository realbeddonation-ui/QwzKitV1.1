		flat = flat.Unit
		local targetPos = r.Position + flat * loopWalkSpeed * math.min(dt, 1 / 30)
		r.CFrame = CFrame.new(targetPos, targetPos + flat)
		r.AssemblyLinearVelocity = Vector3.new(flat.X * loopWalkSpeed, r.AssemblyLinearVelocity.Y, flat.Z * loopWalkSpeed)
	end)
end

