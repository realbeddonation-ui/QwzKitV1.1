function K.stopFly()
	if flyConn then
		flyConn:Disconnect()
		flyConn = nil
	end
	if flyPostConn then
		flyPostConn:Disconnect()
		flyPostConn = nil
	end
	ESP.flyTouchUp = false
	ESP.flyTouchDown = false
	ESP.flyTouchMoveHeld = false
	local h = K.getHumanoid()
	if h then
		h.PlatformStand = false
		h.AutoRotate = true
	end
	local root = K.getRoot()
	if root then
		root.CustomPhysicalProperties = PhysicalProperties.new(0.7, 0.3, 0.5, 0, 0)
		root.AssemblyLinearVelocity = Vector3.zero
	end
end

function K.startFly()
	K.stopFly()
	local stuckSince = nil
	local lastFlatPos = nil
	flyConn = RunService.RenderStepped:Connect(function()
		if not flyOn then return end
		local char = me.Character
		local hum = char and char:FindFirstChildOfClass("Humanoid")
		local root = char and char:FindFirstChild("HumanoidRootPart")
		local cam = K.getCam()
		if not hum or not root or not cam then return end
		local isTouch = UserInputService.TouchEnabled
		-- Keep touch controls responsive on mobile.
		-- Always PlatformStand while flying: on touch, false let Humanoid gravity/floor logic fight velocity and you sink.
		hum.PlatformStand = true
		hum.AutoRotate = false
		if flyHoldY == nil then
			flyHoldY = root.Position.Y
		end
		local look = cam.CFrame.LookVector
		local right = cam.CFrame.RightVector
		local dir = Vector3.zero
		if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir += look end
		if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir -= look end
		if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir -= right end
		if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir += right end
		if UserInputService:IsKeyDown(Enum.KeyCode.Space) then dir += Vector3.yAxis end
		if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) or UserInputService:IsKeyDown(Enum.KeyCode.C) then dir -= Vector3.yAxis end
		if isTouch then
			local md = hum.MoveDirection
			local flat = Vector3.new(md.X, 0, md.Z)
			local fm = flat.Magnitude
			if fm > 0.11 then
				ESP.flyTouchMoveHeld = true
			elseif fm < 0.042 then
				ESP.flyTouchMoveHeld = false
			end
			if ESP.flyTouchMoveHeld and fm > 0.035 then
				dir += flat.Unit
			end
			if ESP.flyTouchUp then
				dir += Vector3.yAxis
			end
			if ESP.flyTouchDown then
				dir -= Vector3.yAxis
			end
		else
			ESP.flyTouchMoveHeld = false
		end
		local anyKeyPressed = dir.Magnitude > 0.01
		if anyKeyPressed then
			flyHoldY = root.Position.Y
			local desiredVel = dir.Unit * flySpeed
			if isTouch then
				local dh = Vector3.new(desiredVel.X, 0, desiredVel.Z)
				if dh.Magnitude > 0.05 and math.abs(desiredVel.Y) < flySpeed * 0.2 then
					desiredVel = dh.Unit * flySpeed
				end
			end
			root.AssemblyLinearVelocity = root.AssemblyLinearVelocity:Lerp(desiredVel, isTouch and 0.32 or 0.22)
			if flyAntiStuckOn and not isTouch then
				local now = os.clock()
				local flatPos = Vector3.new(root.Position.X, 0, root.Position.Z)
				local movedFlat = false
				if lastFlatPos then
					movedFlat = (flatPos - lastFlatPos).Magnitude > 0.03
				end
				lastFlatPos = flatPos
				local v = root.AssemblyLinearVelocity
				local flatVel = Vector3.new(v.X, 0, v.Z).Magnitude
				local slowThreshold = math.max(2, flySpeed * 0.08)
				if flatVel < slowThreshold and not movedFlat then
					if not stuckSince then
						stuckSince = now
					elseif now - stuckSince > 0.3 then
						local flatDir = Vector3.new(dir.X, 0, dir.Z)
						if flatDir.Magnitude > 0.01 then
							flatDir = flatDir.Unit
							root.CFrame = root.CFrame + flatDir * 0.18
						end
						root.AssemblyLinearVelocity = root.AssemblyLinearVelocity:Lerp(desiredVel * 1.15, 0.65)
						pcall(function()
							hum:ChangeState(Enum.HumanoidStateType.Physics)
						end)
						stuckSince = now - 0.15
					end
				else
					stuckSince = nil
				end
			end
		else
			stuckSince = nil
			lastFlatPos = Vector3.new(root.Position.X, 0, root.Position.Z)
			if isTouch then
				flyHoldY = root.Position.Y
				root.AssemblyLinearVelocity = Vector3.zero
			else
				root.CFrame = CFrame.new(Vector3.new(root.Position.X, flyHoldY, root.Position.Z), Vector3.new(root.Position.X + look.X, flyHoldY, root.Position.Z + look.Z))
				root.AssemblyLinearVelocity = Vector3.zero
			end
		end
		root.AssemblyAngularVelocity = Vector3.zero
		root.CFrame = CFrame.lookAt(root.Position, root.Position + look)
	end)
	local function flyKillGravitySink()
		if not flyOn or not UserInputService.TouchEnabled then
			return
		end
		local char = me.Character
		local root = char and char:FindFirstChild("HumanoidRootPart")
		if not root then
			return
		end
		-- Mobile: DN quick button / Ctrl only (not C — conflicts with face-lock default on phone+keyboard).
		local downIntent = ESP.flyTouchDown or UserInputService:IsKeyDown(Enum.KeyCode.LeftControl)
		if downIntent then
			return
		end
		local v = root.AssemblyLinearVelocity
		if v.Y < -0.02 then
			root.AssemblyLinearVelocity = Vector3.new(v.X, 0, v.Z)
		end
	end
	local okPs, postSim = pcall(function()
		return RunService.PostSimulation
	end)
	if okPs and postSim then
		flyPostConn = postSim:Connect(flyKillGravitySink)
	else
		flyPostConn = RunService.Heartbeat:Connect(flyKillGravitySink)
	end
end

