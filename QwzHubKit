				local objName = prompt.ObjectText
				if objName == "" then
					local p = prompt.Parent
					objName = p and p.Name or "?"
				end
				local act = prompt.ActionText
				if act == "" then
					act = "Interact"
				end
				b.Text = string.format("%s — %s  [%s]", objName, act, prompt:GetFullName())
				b.MouseButton1Click:Connect(function()
