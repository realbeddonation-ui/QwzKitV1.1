function K.loopTpVisible(cam, origin, targetPos)
	if not loopTpOnlyIfVisible then
		return true
	end
	local params = RaycastParams.new()
	params.FilterType = Enum.RaycastFilterType.Exclude
	pcall(function()
		params.FilterDescendantsInstances = { me.Character }
	end)
	local delta = targetPos - origin
	local hit = Workspace:Raycast(origin, delta, params)
	if not hit then
		return true
	end
	return (hit.Position - targetPos).Magnitude < 4
end

function K.startLoopTp()
	K.stopLoopTp()
	-- RenderStepped runs after physics; avoids racing anti-TP / sim in many games (same as orbit strafe).
	loopTpConn = RunService.RenderStepped:Connect(function()
		if not loopTpOn then
			return
		end
		local myRoot = K.getRoot()
		local tRoot = K.getLoopTpTargetHrp()
		local cam = K.getCam()
		if not myRoot or not tRoot or not cam then
			return
		end
		local now = os.clock()
		if now - loopTpLastClock < loopTpInterval then
			return
		end
		loopTpLastClock = now
		if (myRoot.Position - tRoot.Position).Magnitude > loopTpMaxDist then
			return
		end
		if loopTpOnlyIfVisible and not K.loopTpVisible(cam, cam.CFrame.Position, tRoot.Position) then
			return
		end
		local back = -tRoot.CFrame.LookVector
		local right = tRoot.CFrame.RightVector
		local baseVec = back * loopTpStudsBehind
		if loopTpOrbit then
			loopTpOrbitAngle += 0.22
			baseVec = baseVec + right * math.sin(loopTpOrbitAngle) * loopTpOrbitRadius
		end
		local jitter = Vector3.new(
			(math.random() - 0.5) * 2 * loopTpJitter,
			(math.random() - 0.5) * loopTpJitter,
			(math.random() - 0.5) * 2 * loopTpJitter
		)
		local pos = tRoot.Position + baseVec + Vector3.new(0, loopTpYOffset, 0) + jitter
		local face = loopTpFaceAway and (tRoot.Position - pos).Unit or tRoot.CFrame.LookVector
		myRoot.CFrame = CFrame.new(pos, pos + face)
		myRoot.AssemblyLinearVelocity = Vector3.zero
		myRoot.AssemblyAngularVelocity = Vector3.zero
	end)
end

