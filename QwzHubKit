-- Fires a ProximityPrompt locally via the engine API (same path as custom prompt UIs).
function K.triggerProximityPrompt(prompt)
	if not prompt or not prompt:IsA("ProximityPrompt") then
		return
	end
	local function promptWorldPos(pp)
		local parent = pp.Parent
		if parent and parent:IsA("Attachment") then
			return parent.WorldPosition
		end
		if parent and parent:IsA("BasePart") then
			return parent.Position
		end
		if parent and parent:IsA("Model") then
			local prim = parent.PrimaryPart or parent:FindFirstChildWhichIsA("BasePart")
			if prim then
				return prim.Position
			end
		end
		local a = pp:FindFirstAncestorWhichIsA("Attachment")
		if a then
			return a.WorldPosition
		end
		local bp = pp:FindFirstAncestorWhichIsA("BasePart")
		if bp then
			return bp.Position
		end
		local m = pp:FindFirstAncestorWhichIsA("Model")
		if m then
			local prim = m.PrimaryPart or m:FindFirstChildWhichIsA("BasePart")
			if prim then
				return prim.Position
			end
		end
		return nil
	end
	local wasEnabled = prompt.Enabled
	if not wasEnabled then
		prompt.Enabled = true
	end
	task.spawn(function()
		local ok, err = pcall(function()
			local root = K.getRoot()
			local oldCf = root and root.CFrame
			local promptPos = promptWorldPos(prompt)
			-- Run loop-TP and prompt trigger at the same time, for longer coverage.
			local tpRunning = false
			if root and promptPos then
				tpRunning = true
				task.spawn(function()
					local tpUntil = os.clock() + 4
					while tpRunning and os.clock() < tpUntil and root.Parent do
						root.CFrame = CFrame.new(promptPos + Vector3.new(0, 2.2, 0), promptPos)
						root.AssemblyLinearVelocity = Vector3.zero
						root.AssemblyAngularVelocity = Vector3.zero
						RunService.Heartbeat:Wait()
					end
					tpRunning = false
				end)
			end
			-- Prefer exploit-style helper if available; Roblox only treats that as a real input for default prompts.
			local fp = (typeof(fireproximityprompt) == "function") and fireproximityprompt or nil
			if fp then
				local hd = prompt.HoldDuration
				if type(hd) ~= "number" or hd <= 0 then
					hd = 1
				end
				-- Most executors interpret the second arg as hold time in seconds.
				fp(prompt, hd)
			else
				-- Fallback: best-effort fake hold. This may NOT behave like a true hold on default-style prompts.
				local hd = prompt.HoldDuration
				if type(hd) ~= "number" or hd <= 0 then
					hd = 1
				end
				prompt:InputHoldBegin()
				task.wait(hd)
				prompt:InputHoldEnd()
			end
			if tpRunning then
				task.wait(0.6)
				tpRunning = false
			end
			if root and oldCf and root.Parent then
				root.CFrame = oldCf
			end
		end)
		if not wasEnabled then
			prompt.Enabled = false
		end
		if not ok then
			warn("[Qwz kit] ProximityPrompt trigger:", err)
		end
	end)
end

