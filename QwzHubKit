function K.isLikelyGrabbedByOtherPlayer()
	local char = me.Character
	if not char then
		return false
	end
	for _, d in char:GetDescendants() do
		if d:IsA("WeldConstraint") then
			local p0 = d.Part0
			local p1 = d.Part1
			if p0 and p1 then
				local p0Mine = p0:IsDescendantOf(char)
				local p1Mine = p1:IsDescendantOf(char)
				if p0Mine ~= p1Mine then
					return true
				end
			end
		elseif d:IsA("AlignPosition") or d:IsA("AlignOrientation") then
			local a0 = d.Attachment0
			local a1 = d.Attachment1
			local p0 = a0 and a0.Parent
			local p1 = a1 and a1.Parent
			if p0 and p1 then
				local p0Mine = p0:IsDescendantOf(char)
				local p1Mine = p1:IsDescendantOf(char)
				if p0Mine ~= p1Mine then
					return true
				end
			end
		end
	end
	return false
end

function K.startAutoForceTp()
	K.stopAutoForceTp()
	local lastPos = nil
	local nextGrabScan = 0
	ESP.autoForceTpConn = RunService.Heartbeat:Connect(function()
		if not ESP.autoForceTpOn then
			return
		end
		local root = K.getRoot()
		local hum = K.getHumanoid()
		if not root or not hum then
			lastPos = nil
			return
		end
		local now = os.clock()
		local grabbedTriggered = false
		if ESP.autoForceTpOnGrab and now >= nextGrabScan then
			nextGrabScan = now + 0.08
			if K.isLikelyGrabbedByOtherPlayer() and (now - ESP.autoForceTpGrabLast) >= math.max(0.05, ESP.autoForceTpGrabCooldown) then
				ESP.autoForceTpGrabLast = now
				grabbedTriggered = true
			end
		end
		local moved = 0
		if lastPos then
			moved = (root.Position - lastPos).Magnitude
		end
		lastPos = root.Position
		local moveIntent = hum.MoveDirection.Magnitude > 0.18
		local canFire = (now - ESP.autoForceTpLast) >= math.max(0.005, ESP.autoForceTpCooldown)
		if ESP.autoForceTpPending or not canFire then
			return
		end
		if (not ESP.autoForceTpLoopMode) and (not grabbedTriggered) and moved < math.max(8, ESP.autoForceTpTriggerDist) and root.AssemblyLinearVelocity.Magnitude < 70 then
			return
		end
		if (not ESP.autoForceTpLoopMode) and (not grabbedTriggered) and moveIntent then
			return
		end
		ESP.autoForceTpPending = true
		ESP.autoForceTpLast = now
		local saved = root.CFrame
		local look = saved.LookVector
		local far = math.clamp(ESP.autoForceTpDistance, 1000000, 1000000000)
		local voidPos = saved.Position + Vector3.new(0, -far, 0)
		root.CFrame = CFrame.new(voidPos, voidPos + look)
		root.AssemblyLinearVelocity = Vector3.zero
		root.AssemblyAngularVelocity = Vector3.zero
		task.delay(math.max(0.005, ESP.autoForceTpReturnDelay), function()
			local r2 = K.getRoot()
			if r2 then
				r2.CFrame = saved
				r2.AssemblyLinearVelocity = Vector3.zero
				r2.AssemblyAngularVelocity = Vector3.zero
			end
			ESP.autoForceTpPending = false
		end)
	end)
end

