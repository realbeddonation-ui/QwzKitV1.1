	if player == me then
		return false
	end
	if not ESP.targetOnly then
		return true
	end
	local t = K.getEspTargetPlayer()
	return t ~= nil and player == t
end

function K.getFilteredPlayersForEspList()
	local list = {}
	local q = string.lower(ESP.playerSearchText or "")
	for _, plr in ipairs(Players:GetPlayers()) do
		if plr ~= me then
			local n = string.lower(plr.Name or "")
			local d = string.lower(plr.DisplayName or "")
			if q == "" or string.find(n, q, 1, true) or string.find(d, q, 1, true) then
				table.insert(list, plr)
			end
		end
	end
	table.sort(list, function(a, b)
		return a.Name < b.Name
	end)
	return list
end

