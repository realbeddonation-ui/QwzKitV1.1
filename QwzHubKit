		hitboxWatcherConn = nil
	end
	for part, _ in pairs(hitboxSavedLTM) do
		if part.Parent then
			part.LocalTransparencyModifier = hitboxSavedLTM[part]
		end
	end
	table.clear(hitboxSavedLTM)
	for part, hl in pairs(hitboxPartHighlights) do
		if hl then
			pcall(function()
				hl:Destroy()
			end)
		end
		hitboxPartHighlights[part] = nil
	end
