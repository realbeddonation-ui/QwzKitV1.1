				statsLabel.BackgroundTransparency = 1
				statsLabel.Size = UDim2.new(1, -16, 1, 0)
				statsLabel.Position = UDim2.fromOffset(8, 0)
				statsLabel.Font = Enum.Font.Code
				statsLabel.TextSize = 13
				statsLabel.TextColor3 = Color3.fromRGB(180, 255, 200)
				statsLabel.TextXAlignment = Enum.TextXAlignment.Left
				statsLabel.TextYAlignment = Enum.TextYAlignment.Top
				statsLabel.TextWrapped = true
				statsLabel.Parent = statsGui
			end
			statsGui.Visible = true
			if statsConn then
				statsConn:Disconnect()
			end
			fpsLast = os.clock()
			fpsFrames = 0
			statsConn = RunService.RenderStepped:Connect(function()
				if not statsOn or not statsGui or not statsGui.Parent then
					return
				end
				fpsFrames += 1
				local now = os.clock()
				local dt = now - fpsLast
				if dt >= 0.35 then
					local fps = math.floor(fpsFrames / dt + 0.5)
					fpsFrames = 0
					fpsLast = now
					local pingMs = 0
					local n = Stats:FindFirstChild("Network")
					local bucket = n and (n:FindFirstChild("ServerStatsItem") or n)
					local pingItem = bucket and bucket:FindFirstChild("Data Ping")
					if pingItem and pingItem.GetValue then
						pingMs = math.floor(pingItem:GetValue() + 0.5)
					end
					statsLabel.Text = string.format("FPS ~%d\nPing ~%d ms", fps, pingMs)
				end
			end)
		else
			if statsGui then
				statsGui.Visible = false
			end
			if statsConn then
				statsConn:Disconnect()
				statsConn = nil
			end
		end
	end)
end

