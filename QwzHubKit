function K.buildMenu()
	local isTouch = UserInputService.TouchEnabled
	if isTouch then
		local cam = Workspace.CurrentCamera
		local vp = cam and cam.ViewportSize or Vector2.new(900, 600)
		local maxW = math.max(260, math.floor(vp.X * 0.62))
		local maxH = math.max(360, math.floor(vp.Y * 0.72))
		ESP.menuWidth = math.floor(math.min(ESP.menuWidth, maxW, 360) + 0.5)
		ESP.menuHeight = math.floor(math.min(ESP.menuHeight, maxH, 500) + 0.5)
		if ESP.menuScale > 0.9 then
			ESP.menuScale = 0.85
		end
		ESP.menuTabTextSize = math.min(ESP.menuTabTextSize, 9)
	end

	local screen = Instance.new("ScreenGui")
	screen.Name = MENU_NAME
	screen.ResetOnSpawn = false
	screen.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
	screen.DisplayOrder = ESP.menuAlwaysTop and 50 or 0
	screen.Parent = guiRoot

	panel = Instance.new("Frame")
	panel.Size = UDim2.fromOffset(ESP.menuWidth, ESP.menuHeight)
	panel.Position = UDim2.new(0, 20, 0.5, -math.floor(ESP.menuHeight / 2))
	panel.BackgroundColor3 = COL.bg
	panel.BackgroundTransparency = ESP.menuBgAlpha
	panel.BorderSizePixel = 0
	panel.Parent = screen
	local panelCorner = K.roundCorners(panel, ESP.menuCorner)
	local shellGrad = Instance.new("UIGradient")
	shellGrad.Rotation = 115
	shellGrad.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0, Color3.fromRGB(24, 28, 48)),
		ColorSequenceKeypoint.new(1, Color3.fromRGB(12, 14, 24)),
	})
	shellGrad.Parent = panel

	local line = Instance.new("UIStroke", panel)
	line.Color = Color3.fromRGB(70, 140, 255)
	line.Thickness = ESP.menuBorderThickness
	line.Transparency = ESP.menuBorderAlpha

	local menuRefs = {
		panel = panel,
		borderStroke = line,
		dragLocked = ESP.menuDragLock,
		scaleObj = nil,
		panelCorner = panelCorner,
		screen = screen,
	}

	-- Mobile-friendly toggle (keeps PC minus-key behavior unchanged).
	if isTouch then
		local inset = GuiService:GetGuiInset()
		local openBtn = Instance.new("TextButton")
		openBtn.Name = "MobileMenuToggle"
		openBtn.AutoButtonColor = true
		openBtn.Text = "≡"
		openBtn.Font = Enum.Font.GothamBlack
		openBtn.TextSize = 18
		openBtn.TextColor3 = Color3.fromRGB(235, 240, 255)
		openBtn.BackgroundColor3 = Color3.fromRGB(35, 40, 65)
		openBtn.BackgroundTransparency = 0.1
		openBtn.BorderSizePixel = 0
		openBtn.Size = UDim2.fromOffset(38, 38)
		openBtn.Position = UDim2.new(0, 10 + inset.X, 0, 10 + inset.Y)
		openBtn.ZIndex = 20
		openBtn.Parent = screen
		K.roundCorners(openBtn, 10)
		local s = Instance.new("UIStroke", openBtn)
		s.Thickness = 1
		s.Transparency = 0.6
		s.Color = Color3.fromRGB(120, 170, 255)
		openBtn.Activated:Connect(function()
			panel.Visible = not panel.Visible
		end)
	end

	local dragHeight = isTouch and 42 or 48
	local topBar = Instance.new("TextButton")
	topBar.AutoButtonColor = false
	topBar.Text = ""
	topBar.Position = UDim2.fromOffset(0, 0)
	topBar.Size = UDim2.new(1, 0, 0, dragHeight)
	topBar.BackgroundColor3 = COL.bgTop
	topBar.BackgroundTransparency = ESP.menuTopAlpha
	topBar.BorderSizePixel = 0
	topBar.ZIndex = 2
	topBar.Parent = panel
	K.roundCorners(topBar, 14)

	local topShine = Instance.new("UIGradient")
	topShine.Rotation = 90
	topShine.Color = ColorSequence.new(Color3.fromRGB(45, 55, 90), Color3.fromRGB(22, 26, 42))
	topShine.Transparency = NumberSequence.new(0.5, 1)
	topShine.Parent = topBar

	local title = Instance.new("TextLabel")
	title.BackgroundTransparency = 1
	title.Position = UDim2.fromOffset(14, 6)
	title.Size = UDim2.new(1, -80, 0, 22)
	title.Font = Enum.Font.GothamBlack
	title.TextSize = isTouch and 15 or 17
	title.TextXAlignment = Enum.TextXAlignment.Left
	title.TextColor3 = Color3.new(1, 1, 1)
	title.Text = "Qwz kit"
	title.ZIndex = 3
	title.Active = false
	title.Parent = topBar

	local subtitle = Instance.new("TextLabel")
	subtitle.BackgroundTransparency = 1
	subtitle.Position = UDim2.fromOffset(14, 26)
	subtitle.Size = UDim2.new(1, -80, 0, 18)
	subtitle.Font = Enum.Font.GothamMedium
	subtitle.TextSize = isTouch and 10 or 11
	subtitle.TextXAlignment = Enum.TextXAlignment.Left
	subtitle.TextColor3 = COL.muted
	subtitle.Text = isTouch and "Drag header to move · button toggles · close hides"
		or "Drag header to move · − key toggles · − closes"
	subtitle.ZIndex = 3
	subtitle.Active = false
	subtitle.Parent = topBar
	subtitle.Visible = ESP.menuShowSubtitle

	local closeBtn = Instance.new("TextButton")
	closeBtn.Name = "CloseMenu"
	closeBtn.AutoButtonColor = false
	closeBtn.Text = "−"
	closeBtn.Font = Enum.Font.GothamBlack
	closeBtn.TextSize = 22
	closeBtn.TextColor3 = Color3.fromRGB(220, 230, 255)
	closeBtn.BackgroundColor3 = Color3.fromRGB(45, 50, 75)
	closeBtn.Size = UDim2.fromOffset(40, 36)
	closeBtn.Position = UDim2.new(1, -48, 0, 6)
	closeBtn.ZIndex = 4
	closeBtn.Parent = topBar
	K.roundCorners(closeBtn, 8)
	closeBtn.Visible = ESP.menuShowClose
	closeBtn.MouseButton1Click:Connect(function()
		panel.Visible = false
	end)

	local dragging = false
	local grabPos = nil
	local panelPosWhenGrabbed = nil
	topBar.InputBegan:Connect(function(input)
		if menuRefs.dragLocked then
			return
		end
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			if input.Position.X < topBar.AbsolutePosition.X + topBar.AbsoluteSize.X - 50 then
				dragging = true
				grabPos = input.Position
				panelPosWhenGrabbed = panel.Position
			end
		end
	end)
	topBar.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end)
	UserInputService.InputChanged:Connect(function(input)
		if not dragging then
			return
		end
		if input.UserInputType ~= Enum.UserInputType.MouseMovement and input.UserInputType ~= Enum.UserInputType.Touch then
			return
		end
		local shift = input.Position - grabPos
		panel.Position = UDim2.new(
			panelPosWhenGrabbed.X.Scale,
			panelPosWhenGrabbed.X.Offset + shift.X,
			panelPosWhenGrabbed.Y.Scale,
			panelPosWhenGrabbed.Y.Offset + shift.Y
		)
	end)
	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end)

	local tabH = isTouch and 32 or 36
	local tabY = dragHeight
	local tabBar = Instance.new("Frame")
	tabBar.BackgroundColor3 = Color3.fromRGB(18, 20, 32)
	tabBar.BackgroundTransparency = ESP.menuTabAlpha
	tabBar.BorderSizePixel = 0
	tabBar.ClipsDescendants = true
	tabBar.Position = UDim2.fromOffset(0, tabY)
	tabBar.Size = UDim2.new(1, 0, 0, tabH)
	tabBar.Parent = panel

	local tabScroll = Instance.new("ScrollingFrame")
	tabScroll.Name = "TabScroll"
	tabScroll.BackgroundTransparency = 1
	tabScroll.BorderSizePixel = 0
	tabScroll.Position = UDim2.fromOffset(0, 0)
	tabScroll.Size = UDim2.new(1, 0, 1, 0)
	tabScroll.CanvasSize = UDim2.new(0, 0, 0, 0)
	tabScroll.AutomaticCanvasSize = Enum.AutomaticSize.X
	tabScroll.ScrollingDirection = Enum.ScrollingDirection.X
	tabScroll.ScrollBarThickness = 3
	tabScroll.ScrollBarImageColor3 = Color3.fromRGB(90, 130, 220)
	tabScroll.ScrollingEnabled = true
	tabScroll.Parent = tabBar
	if ESP.menuHideTabScrollbar then
		tabScroll.ScrollBarThickness = 0
	end

	local tabLayout = Instance.new("UIListLayout")
	tabLayout.FillDirection = Enum.FillDirection.Horizontal
	tabLayout.SortOrder = Enum.SortOrder.LayoutOrder
	tabLayout.Padding = UDim.new(0, 3)
	tabLayout.Parent = tabScroll

	local tabPad = Instance.new("UIPadding", tabScroll)
	tabPad.PaddingLeft = UDim.new(0, 6)
	tabPad.PaddingRight = UDim.new(0, 6)
