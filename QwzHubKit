function K.runAutoForceTpBurst()
	if ESP.autoForceTpBurstRunning then
		return
	end
	local root = K.getRoot()
	if not root then
		return
	end
	ESP.autoForceTpBurstRunning = true
	ESP.autoForceTpBurstCancel = false
	ESP.autoForceTpPending = true
	task.spawn(function()
		local count = math.clamp(math.floor(ESP.autoForceTpBurstCount), 1, 5000)
		local far = math.clamp(ESP.autoForceTpDistance, 1000000, 1000000000)
		local hold = math.max(0, ESP.autoForceTpReturnDelay)
		for i = 1, count do
			if ESP.autoForceTpBurstCancel then
				break
			end
			local r = K.getRoot()
			if not r then
				break
			end
			local saved = r.CFrame
			local look = saved.LookVector
			local voidPos = saved.Position + Vector3.new(0, -far, 0)
			r.CFrame = CFrame.new(voidPos, voidPos + look)
			r.AssemblyLinearVelocity = Vector3.zero
			r.AssemblyAngularVelocity = Vector3.zero
			-- Keep at least one frame in void so games register a real TP.
			if hold > 0.005 then
				task.wait(hold)
			else
				RunService.Heartbeat:Wait()
			end
			r.CFrame = saved
			r.AssemblyLinearVelocity = Vector3.zero
			r.AssemblyAngularVelocity = Vector3.zero
			if hold <= 0.005 and i % 30 == 0 then
				RunService.Heartbeat:Wait()
			end
		end
		ESP.autoForceTpPending = false
		ESP.autoForceTpBurstRunning = false
		ESP.autoForceTpBurstCancel = false
	end)
end

