	if loopTpStatusLabel then
		local n = loopTpUserId and (K.playerByUserId(loopTpUserId) and K.playerByUserId(loopTpUserId).Name or "?") or "(pick player)"
		loopTpStatusLabel.Text = string.format(
			"Loop TP: %s | behind %.1f y+%.1f max %.0f every %.3fs jitter %.2f orbit %s | target %s",
			loopTpOn and "ON" or "OFF",
			loopTpStudsBehind,
			loopTpYOffset,
			loopTpMaxDist,
			loopTpInterval,
			loopTpJitter,
			loopTpOrbit and "on" or "off",
			n
		)
	end
end

