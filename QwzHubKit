function K.startLoopWalk()
	K.stopLoopWalk()
	loopWalkConn = RunService.RenderStepped:Connect(function(dt)
		if not loopWalkOn then
			return
		end
		local h = K.getHumanoid()
		local r = K.getRoot()
		if not h or not r or h.Health <= 0 then
			return
		end
		local dir = h.MoveDirection
		if dir.Magnitude < 0.001 then
			return
		end
		local flat = Vector3.new(dir.X, 0, dir.Z)
		if flat.Magnitude < 0.001 then
			return
		end
		flat = flat.Unit
		local targetPos = r.Position + flat * loopWalkSpeed * math.min(dt, 1 / 30)
		r.CFrame = CFrame.new(targetPos, targetPos + flat)
		r.AssemblyLinearVelocity = Vector3.new(flat.X * loopWalkSpeed, r.AssemblyLinearVelocity.Y, flat.Z * loopWalkSpeed)
	end)
end

