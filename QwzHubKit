		RunService:UnbindFromRenderStep(MENU_NAME .. "_CamLock")
	end)
	local cam = Workspace.CurrentCamera
	if cam and ESP.opCameraLockSavedType ~= nil then
		pcall(function()
			cam.CameraType = ESP.opCameraLockSavedType
			cam.CameraSubject = ESP.opCameraLockSavedSubject
		end)
	end
	ESP.opCameraLockSavedType = nil
	ESP.opCameraLockSavedSubject = nil
	ESP.opCamLockSmoothCf = nil
	ESP.opCamLockLastTgtUid = nil
	ESP.opCamLockLastStepT = nil
end

function K.cameraLockStep(now)
	if not ESP.opCameraLockOn then
		return
	end
	local plr = K.getOpCombatTargetPlayer()
	local head = plr and K.getHead(plr)
	local myRoot = K.getRoot()
	local cam = Workspace.CurrentCamera
	if not head or not myRoot or not cam then
		return
	end
	local uid = plr.UserId
	if ESP.opCamLockLastTgtUid ~= uid then
		ESP.opCamLockLastTgtUid = uid
		ESP.opCamLockSmoothCf = nil
		ESP.opCamLockLastStepT = nil
	end
	local prevT = ESP.opCamLockLastStepT
	ESP.opCamLockLastStepT = now
	local dt = prevT and math.clamp(now - prevT, 0.008, 0.12) or (1 / 60)
	local headPos = head.Position
	if ESP.opFaceLockOn then
		myRoot.CFrame = CFrame.new(myRoot.Position, headPos)
	end
	if ESP.opSpinOn and myRoot then
		local cfSpin = myRoot.CFrame
		myRoot.CFrame = cfSpin * CFrame.Angles(0, math.rad(ESP.opSpinSpeed / 60), 0)
	end
	local back = ESP.opCameraLockBack or 10
	local up = ESP.opCameraLockUp or 2.5
	local cf = myRoot.CFrame
	local camPos = cf.Position - cf.LookVector * back + Vector3.new(0, up, 0)
	local smoothLook = headPos
	local prevCf = ESP.opCamLockSmoothCf
	if prevCf then
		local prevLook = prevCf.Position + prevCf.LookVector * 80
		if (headPos - prevLook).Magnitude > 45 then
			smoothLook = headPos
			prevCf = nil
			ESP.opCamLockSmoothCf = nil
		else
			smoothLook = prevLook:Lerp(headPos, math.clamp(dt * 18, 0.12, 0.55))
		end
	end
	local targetCf = CFrame.lookAt(camPos, smoothLook)
	if prevCf then
		targetCf = prevCf:Lerp(targetCf, math.clamp(dt * 11, 0.15, 0.5))
	end
	ESP.opCamLockSmoothCf = targetCf
	cam.CFrame = targetCf
end

function K.setCameraLockRunning()
	if ESP.opCameraLockOn then
		local cam = Workspace.CurrentCamera
		if cam and ESP.opCameraLockSavedType == nil then
			ESP.opCameraLockSavedType = cam.CameraType
			ESP.opCameraLockSavedSubject = cam.CameraSubject
		end
		if cam then
			cam.CameraType = Enum.CameraType.Scriptable
		end
		pcall(function()
			RunService:UnbindFromRenderStep(MENU_NAME .. "_CamLock")
		end)
		-- After default camera work; keeps HRP/face-lock and scriptable cam in one late pass (reduces jitter vs RenderStepped).
		RunService:BindToRenderStep(MENU_NAME .. "_CamLock", 2147483644, K.cameraLockStep)
	else
		K.stopCameraLock()
	end
end

