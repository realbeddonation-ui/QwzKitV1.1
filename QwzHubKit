function K.menuFillCustomizeTab(pageCustom, menuRefs)
	local numRows = {}
	local rgbSyncers = {}

	local function snapMenuCfgFromCol()
		local function tri(c3)
			return {
				math.clamp(math.floor(c3.R * 255 + 0.5), 0, 255),
				math.clamp(math.floor(c3.G * 255 + 0.5), 0, 255),
				math.clamp(math.floor(c3.B * 255 + 0.5), 0, 255),
			}
		end
		MENU_CFG.panel = tri(COL.bg)
		MENU_CFG.top = tri(COL.bgTop)
		MENU_CFG.tabsIdle = tri(COL.tabIdle)
		MENU_CFG.tabsOn = tri(COL.tabOn)
		MENU_CFG.outline = tri(COL.tabGlow)
		MENU_CFG.buttons = tri(COL.btn)
		MENU_CFG.buttonsHot = tri(COL.btnHot)
		MENU_CFG.text = tri(COL.muted)
		MENU_CFG.accent = tri(COL.accent)
		MENU_CFG.accentSoft = tri(COL.accentSoft)
		MENU_CFG.list = tri(COL.listBg)
		MENU_CFG.input = tri(COL.inputBg)
	end

	local function ensureScale()
		if menuRefs.scaleObj and menuRefs.scaleObj.Parent then
			return menuRefs.scaleObj
		end
		local s = Instance.new("UIScale")
		s.Scale = ESP.menuScale
		s.Parent = panel
		menuRefs.scaleObj = s
		return s
	end

	local function makeNumRow(title, get, set, step, fmt)
		local row = Instance.new("Frame")
		row.BackgroundTransparency = 1
		row.Size = UDim2.new(1, 0, 0, 30)
		row.Parent = pageCustom
		local lay = Instance.new("UIListLayout", row)
		lay.FillDirection = Enum.FillDirection.Horizontal
		lay.HorizontalAlignment = Enum.HorizontalAlignment.Right
		lay.Padding = UDim.new(0, 6)
		local lbl = Instance.new("TextLabel")
		lbl.BackgroundTransparency = 1
		lbl.Size = UDim2.new(1, -90, 1, 0)
		lbl.Font = Enum.Font.Gotham
		lbl.TextSize = 11
		lbl.TextXAlignment = Enum.TextXAlignment.Left
		lbl.TextColor3 = Color3.fromRGB(200, 205, 220)
		lbl.Parent = row
		local down = Instance.new("TextButton")
		down.Size = UDim2.fromOffset(28, 24)
		down.Text = "-"
		down.Parent = row
		down.AutoButtonColor = false
		down:SetAttribute("KitStepBtn", true)
		K.roundCorners(down, 4)
		local up = Instance.new("TextButton")
		up.Size = UDim2.fromOffset(28, 24)
		up.Text = "+"
		up.Parent = row
		up.AutoButtonColor = false
		up:SetAttribute("KitStepBtn", true)
		K.roundCorners(up, 4)
		local rec = {}
		rec.sync = function()
			lbl.Text = title .. ": " .. string.format(fmt or "%.2f", get())
		end
		down.Activated:Connect(function()
			set(get() - step)
			rec.sync()
		end)
		up.Activated:Connect(function()
			set(get() + step)
			rec.sync()
		end)
		rec.sync()
		table.insert(numRows, rec)
		return rec
	end

	local function applyMenuVisuals()
		if menuRefs.panel then
			menuRefs.panel.Size = UDim2.fromOffset(ESP.menuWidth, ESP.menuHeight)
			menuRefs.panel.BackgroundTransparency = ESP.menuBgAlpha
		end
		if menuRefs.panelCorner then
			menuRefs.panelCorner.CornerRadius = UDim.new(0, ESP.menuCorner)
		end
		if menuRefs.topBar then
			menuRefs.topBar.BackgroundTransparency = ESP.menuTopAlpha
		end
		if menuRefs.tabBar then
			menuRefs.tabBar.BackgroundTransparency = ESP.menuTabAlpha
		end
		if menuRefs.mainArea then
			menuRefs.mainArea.BackgroundTransparency = 1
		end
		if menuRefs.borderStroke then
			menuRefs.borderStroke.Thickness = ESP.menuBorderThickness
			menuRefs.borderStroke.Transparency = ESP.menuBorderAlpha
			menuRefs.borderStroke.Color = COL.tabGlow
		end
		if menuRefs.subtitle then
			menuRefs.subtitle.Visible = ESP.menuShowSubtitle
		end
		if menuRefs.closeBtn then
			menuRefs.closeBtn.Visible = ESP.menuShowClose
		end
		if menuRefs.tabScroll then
			menuRefs.tabScroll.ScrollBarThickness = ESP.menuHideTabScrollbar and 0 or 3
		end
		if menuRefs.tabButtons then
			for _, b in ipairs(menuRefs.tabButtons) do
				b.TextSize = ESP.menuTabTextSize
			end
		end
		if menuRefs.title then
			menuRefs.title.TextColor3 = Color3.fromRGB(235, 235, 235)
		end
		if menuRefs.closeBtn then
			menuRefs.closeBtn.BackgroundColor3 = COL.tabIdle
			menuRefs.closeBtn.TextColor3 = Color3.fromRGB(235, 235, 235)
		end
		if menuRefs.tabScroll then
			menuRefs.tabScroll.ScrollBarImageColor3 = COL.tabGlow
		end
		if menuRefs.mobileOpenBtn then
			menuRefs.mobileOpenBtn.BackgroundColor3 = COL.tabIdle
			menuRefs.mobileOpenBtn.TextColor3 = Color3.fromRGB(235, 235, 235)
		end
		if menuRefs.mobileOpenStroke then
			menuRefs.mobileOpenStroke.Color = COL.tabGlow
		end
		if panel then
			for _, d in ipairs(panel:GetDescendants()) do
				if d:IsA("TextButton") and not d:GetAttribute("KitTabNav") and d.Parent ~= menuRefs.tabScroll and d ~= menuRefs.closeBtn and d ~= btnMain then
					if d:GetAttribute("KitStepBtn") then
						d.AutoButtonColor = false
						d.BackgroundColor3 = COL.btn
						d.TextColor3 = K.getReadableTextColor(COL.btn)
						local ss = d:FindFirstChildOfClass("UIStroke")
						if ss then
							ss.Color = COL.tabGlow
						end
					else
						d.BackgroundColor3 = COL.btn
						d.TextColor3 = K.getReadableTextColor(COL.btn)
						local s = d:FindFirstChildOfClass("UIStroke")
						if s then
							s.Color = COL.tabGlow
						end
					end
				elseif d:IsA("TextBox") then
					d.BackgroundColor3 = COL.inputBg
					d.TextColor3 = Color3.fromRGB(250, 250, 250)
					d.PlaceholderColor3 = Color3.fromRGB(205, 205, 205)
				elseif d:IsA("ScrollingFrame") then
					d.ScrollBarImageColor3 = COL.accentSoft
					if d ~= menuRefs.tabScroll then
						d.BackgroundColor3 = COL.bgTop
					end
				elseif d:IsA("TextLabel") then
					if d:GetAttribute("KitMutedLabel") then
						d.TextColor3 = COL.muted
					elseif d.TextColor3 == COL.muted or d.TextColor3 == Color3.fromRGB(200, 205, 220) then
						d.TextColor3 = COL.muted
					end
				end
			end
		end
		if menuRefs.screen then
			menuRefs.screen.DisplayOrder = ESP.menuAlwaysTop and 50 or 0
		end
		for _, rs in ipairs(rgbSyncers) do
			pcall(rs)
		end
		local sc = ESP.menuScale
		if UserInputService.TouchEnabled then
			local cam = Workspace.CurrentCamera
			local vp = cam and cam.ViewportSize or Vector2.new(800, 600)
			local needW = ESP.menuWidth * ESP.menuScale
			local needH = ESP.menuHeight * ESP.menuScale
			local maxW = math.max(200, vp.X * 0.92)
			local maxH = math.max(160, vp.Y * 0.52)
			local fit = math.min(1, maxW / math.max(1, needW), maxH / math.max(1, needH))
			sc = math.clamp(ESP.menuScale * fit, 0.5, ESP.menuScale)
		end
		ensureScale().Scale = sc
		menuRefs.dragLocked = ESP.menuDragLock
	end

	local function applyRainbow()
		if ESP.menuRainbowBorderOn then
			if ESP.menuRainbowConn then
				ESP.menuRainbowConn:Disconnect()
			end
			local stroke = menuRefs.borderStroke
			ESP.menuRainbowConn = RunService.RenderStepped:Connect(function()
				if not stroke or not stroke.Parent then
					return
				end
				local t = os.clock() * 0.35
				stroke.Color = Color3.fromHSV(t % 1, 0.7, 1)
			end)
		else
			if ESP.menuRainbowConn then
				ESP.menuRainbowConn:Disconnect()
				ESP.menuRainbowConn = nil
			end
			if menuRefs.borderStroke then
				menuRefs.borderStroke.Color = COL.tabGlow
			end
		end
	end

	local function applySimpleTheme(base, contrast, accentShift)
		local function byte(n)
			return math.clamp(math.floor(n + 0.5), 0, 255)
		end
		local b = byte(base)
		local c = byte(contrast)
		local a = math.clamp(math.floor(accentShift + 0.5), -160, 160)
		MENU_CFG.themeTone = b
		MENU_CFG.textContrast = c
		MENU_CFG.accentShift = a
		COL.bg = Color3.fromRGB(b, b, b)
		COL.bgTop = Color3.fromRGB(byte(b - 20), byte(b - 20), byte(b - 20))
		COL.tabIdle = Color3.fromRGB(byte(b - 38), byte(b - 38), byte(b - 38))
		COL.tabOn = Color3.fromRGB(byte(b - 80), byte(b - 80), byte(b - 80))
		COL.btn = Color3.fromRGB(byte(b - 56), byte(b - 56), byte(b - 56))
		COL.btnHot = Color3.fromRGB(byte(b - 74), byte(b - 74), byte(b - 74))
		COL.muted = Color3.fromRGB(c, c, c)
		COL.tabGlow = Color3.fromRGB(byte(c - 10), byte(c - 10), byte(c - 10))
		local ac = byte((b - 88) + a)
		local ac2 = byte(ac - 18)
		local lb = byte((b - 168) + math.floor(a * 0.4))
		local ib = byte((b - 48) + math.floor(a * 0.4))
		COL.accent = Color3.fromRGB(ac, ac, ac)
		COL.accentSoft = Color3.fromRGB(ac2, ac2, ac2)
		COL.listBg = Color3.fromRGB(lb, lb, lb)
		COL.inputBg = Color3.fromRGB(ib, ib, ib)
		snapMenuCfgFromCol()
		applyMenuVisuals()
	end

	K.addSectionLabel(pageCustom, "SIZE AND LAYOUT")
	makeNumRow("Scale", function()
		return ESP.menuScale
	end, function(v)
		ESP.menuScale = v
		applyMenuVisuals()
	end, 0.05, "%.2f")
	makeNumRow("Width", function()
		return ESP.menuWidth
	end, function(v)
		ESP.menuWidth = math.floor(v + 0.5)
		applyMenuVisuals()
	end, 10, "%.0f")
	makeNumRow("Height", function()
		return ESP.menuHeight
	end, function(v)
		ESP.menuHeight = math.floor(v + 0.5)
		applyMenuVisuals()
	end, 10, "%.0f")
	makeNumRow("Corner radius", function()
		return ESP.menuCorner
	end, function(v)
		ESP.menuCorner = math.floor(v + 0.5)
		applyMenuVisuals()
	end, 1, "%.0f")

	K.addSectionLabel(pageCustom, "VISUAL TUNING")
	makeNumRow("Theme tone", function()
		return math.floor(COL.bg.R * 255 + 0.5)
	end, function(v)
		applySimpleTheme(v, MENU_CFG.textContrast, MENU_CFG.accentShift)
	end, 5, "%.0f")
	makeNumRow("Accent strength", function()
		return math.floor(COL.tabOn.R * 255 + 0.5)
	end, function(v)
		local n = math.clamp(math.floor(v + 0.5), 0, 255)
		COL.tabOn = Color3.fromRGB(n, n, n)
		COL.btn = Color3.fromRGB(math.clamp(n + 20, 0, 255), math.clamp(n + 20, 0, 255), math.clamp(n + 20, 0, 255))
		COL.btnHot = Color3.fromRGB(math.clamp(n + 2, 0, 255), math.clamp(n + 2, 0, 255), math.clamp(n + 2, 0, 255))
		snapMenuCfgFromCol()
		applyMenuVisuals()
	end, 5, "%.0f")
	makeNumRow("Text contrast", function()
		return MENU_CFG.textContrast
	end, function(v)
		applySimpleTheme(MENU_CFG.themeTone, v, MENU_CFG.accentShift)
	end, 4, "%.0f")
	makeNumRow("Accent shift", function()
		return MENU_CFG.accentShift
	end, function(v)
		applySimpleTheme(MENU_CFG.themeTone, MENU_CFG.textContrast, v)
	end, 4, "%.0f")
	K.addSectionLabel(pageCustom, "THEME PRESETS")
	local monoDarkBtn = K.makeToggleButton(pageCustom, "Preset: Dark gray", function()
		applySimpleTheme(95, 228, 0)
	end)
	monoDarkBtn.BackgroundColor3 = COL.btn
	local monoMidBtn = K.makeToggleButton(pageCustom, "Preset: Mid gray", function()
		applySimpleTheme(125, 228, 0)
	end)
	monoMidBtn.BackgroundColor3 = COL.btn
	local monoLightBtn = K.makeToggleButton(pageCustom, "Preset: Light gray", function()
		applySimpleTheme(150, 228, 0)
	end)
	monoLightBtn.BackgroundColor3 = COL.btn
	K.addSectionLabel(pageCustom, "COLORS (swatch + R/G/B)")
	local rgbHint = Instance.new("TextLabel")
	rgbHint.BackgroundTransparency = 1
	rgbHint.Font = Enum.Font.Gotham
	rgbHint.TextSize = 10
	rgbHint.TextXAlignment = Enum.TextXAlignment.Left
	rgbHint.TextWrapped = true
	rgbHint.TextColor3 = COL.muted
	rgbHint:SetAttribute("KitMutedLabel", true)
	rgbHint.Text = "Square shows the live color. Theme tone / presets use a neutral ramp; after that, edit RGB here. Defaults: table MENU_CFG near top of script."
	rgbHint.Size = UDim2.new(1, 0, 0, 36)
	rgbHint.Parent = pageCustom
	local function rgbReadout(title, c)
		return string.format("%s  R %.0f  G %.0f  B %.0f", title, c.R * 255, c.G * 255, c.B * 255)
	end
	local function makeRgbBlock(title, getter, setter)
		local label = Instance.new("TextLabel")
		label.BackgroundTransparency = 1
		label.Size = UDim2.new(1, 0, 0, 20)
		label.Font = Enum.Font.Gotham
		label.TextSize = 11
		label.TextXAlignment = Enum.TextXAlignment.Left
		label.TextColor3 = COL.muted
		label:SetAttribute("KitMutedLabel", true)
		label.Parent = pageCustom
		local row = Instance.new("Frame")
		row.BackgroundTransparency = 1
		row.Size = UDim2.new(1, 0, 0, 30)
		row.Parent = pageCustom
		local lay = Instance.new("UIListLayout", row)
		lay.FillDirection = Enum.FillDirection.Horizontal
		lay.HorizontalAlignment = Enum.HorizontalAlignment.Right
		lay.VerticalAlignment = Enum.VerticalAlignment.Center
		lay.Padding = UDim.new(0, 6)
		local sw = Instance.new("Frame")
		sw.BorderSizePixel = 0
		sw.Size = UDim2.fromOffset(48, 24)
		sw.LayoutOrder = -100
		sw.Parent = row
		K.roundCorners(sw, 6)
		local swS = Instance.new("UIStroke", sw)
		swS.Thickness = 1
		swS.Transparency = 0.4
		swS.Color = COL.tabGlow
		local function sync()
			local cur = getter()
			label.Text = rgbReadout(title, cur)
			sw.BackgroundColor3 = cur
		end
		local function addBtn(txt, channel, delta)
			local b = Instance.new("TextButton")
			b.Size = UDim2.fromOffset(40, 26)
			b.Text = txt
			b.Font = Enum.Font.GothamBold
			b.TextSize = 11
			b.AutoButtonColor = false
			b:SetAttribute("KitStepBtn", true)
			b.Parent = row
			K.roundCorners(b, 6)
			b.Activated:Connect(function()
				local c = getter()
				local r, g, b2 = c.R * 255, c.G * 255, c.B * 255
				if channel == "r" then
					r += delta
				elseif channel == "g" then
					g += delta
				else
					b2 += delta
				end
				setter(Color3.fromRGB(
					math.clamp(math.floor(r + 0.5), 0, 255),
					math.clamp(math.floor(g + 0.5), 0, 255),
					math.clamp(math.floor(b2 + 0.5), 0, 255)
				))
				snapMenuCfgFromCol()
				applyMenuVisuals()
				sync()
			end)
		end
		addBtn("R-", "r", -5)
		addBtn("R+", "r", 5)
		addBtn("G-", "g", -5)
		addBtn("G+", "g", 5)
		addBtn("B-", "b", -5)
		addBtn("B+", "b", 5)
		table.insert(rgbSyncers, sync)
		sync()
	end
	makeRgbBlock("Panel", function()
		return COL.bg
	end, function(v)
		COL.bg = v
	end)
	makeRgbBlock("Buttons", function()
		return COL.btn
