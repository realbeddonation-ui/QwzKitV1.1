function K.targetKitStartNav()
	if not ESP.targetKitUserId then
		return false
	end
	local tpl = K.playerByUserId(ESP.targetKitUserId)
	local troot = tpl and tpl.Character and tpl.Character:FindFirstChild("HumanoidRootPart")
	if not troot then
		return false
	end
	local wasChasing = ESP.targetKitChasing
	pcall(function()
		RunService:UnbindFromRenderStep(MENU_NAME .. "_TargetKitNav")
	end)
	ESP.targetKitChasing = false
	if not wasChasing then
		ESP.targetKitSavedFlyOn = flyOn
		if flyOn then
			flyOn = false
			K.stopFly()
		end
	end
	ESP.targetKitChasing = true
	if not wasChasing then
		local r0 = K.getRoot()
		ESP.targetKitArcStartY = r0 and r0.Position.Y or 0
		ESP.targetKitArcPhase = 1
	end
	RunService:BindToRenderStep(MENU_NAME .. "_TargetKitNav", 2147483643, function()
		if not ESP.targetKitChasing then
			return
		end
		local char = me.Character
		local hum = char and char:FindFirstChildOfClass("Humanoid")
		local root = char and char:FindFirstChild("HumanoidRootPart")
		if not hum or not root then
			return
		end
		hum.PlatformStand = true
		hum.AutoRotate = false
		local tpl2 = K.playerByUserId(ESP.targetKitUserId)
		local tr = tpl2 and tpl2.Character and tpl2.Character:FindFirstChild("HumanoidRootPart")
		if not tr then
			K.targetKitStopNav()
			if ESP.targetKitStatusLbl then
				ESP.targetKitStatusLbl.Text = "Target left — stopped."
			end
			return
		end
		local goal = tr.Position + Vector3.new(0, 1.5, 0)
		local from = root.Position
		local dist = (goal - from).Magnitude
		if dist < 5 then
			root.AssemblyLinearVelocity = Vector3.zero
			root.AssemblyAngularVelocity = Vector3.zero
			if ESP.targetKitStatusLbl then
				ESP.targetKitStatusLbl.Text = "Within range of " .. tpl2.Name .. " (~" .. string.format("%.0f", dist) .. " studs)."
			end
			return
		end
		local steer
		local phaseTag = ""
		if ESP.targetKitArcMode then
			local clear = ESP.targetKitArcClear
			local maxRise = ESP.targetKitArcMaxRise
			local descD = ESP.targetKitArcDescDist
			local flatDelta = Vector3.new(goal.X - from.X, 0, goal.Z - from.Z)
			local flatDist = flatDelta.Magnitude
			local baseY = ESP.targetKitArcStartY or from.Y
			local cruiseY = math.max(goal.Y + clear, baseY + math.min(clear, 14))
			local horizProbe = math.min(math.max(flatDist, 10), 72)
			if ESP.targetKitArcPhase >= 3 then
				phaseTag = "drop→chase"
				steer = K.targetKitSteerDir(from, goal, char, ESP.targetKitAvoid)
			elseif ESP.targetKitArcPhase == 2 then
				phaseTag = "cruise"
				local holdY = math.max(cruiseY - 1.5, goal.Y + clear * 0.88)
				holdY = math.min(holdY, baseY + maxRise + clear)
				local aerialGoal = Vector3.new(goal.X, holdY, goal.Z)
				local toG = aerialGoal - from
				if toG.Magnitude < 0.15 then
					steer = Vector3.yAxis
				else
					steer = toG.Unit
				end
				if ESP.targetKitAvoid then
					local alt = K.targetKitSteerDir(from, aerialGoal, char, true)
					if alt.Magnitude > 0.02 and alt:Dot(steer) > 0.2 then
						steer = (steer * 0.55 + alt * 0.45).Unit
					end
				end
				local horizOk = not K.targetKitHorizontalBlocked(from, goal, char, 1.1, horizProbe + 6)
				if flatDist < descD and horizOk then
					ESP.targetKitArcPhase = 3
				elseif from.Y <= goal.Y + clear * 0.35 and flatDist < descD * 1.35 and horizOk then
					ESP.targetKitArcPhase = 3
				end
			else
				phaseTag = "climb"
				local flatDir = flatDist > 0.45 and flatDelta.Unit or Vector3.zero
				steer = (Vector3.yAxis * 0.74 + flatDir * 0.26)
				if steer.Magnitude < 0.06 then
					steer = Vector3.yAxis
				else
					steer = steer.Unit
				end
				local blocked = K.targetKitHorizontalBlocked(from, goal, char, 1.5, horizProbe)
				local highEnough = from.Y >= goal.Y + clear - 1.2
				local ceiling = baseY + maxRise
				if (highEnough and not blocked) or from.Y >= ceiling then
					ESP.targetKitArcPhase = 2
				end
			end
		else
			steer = K.targetKitSteerDir(from, goal, char, ESP.targetKitAvoid)
		end
		if steer.Magnitude < 0.02 then
			steer = (goal - from).Unit
		end
		root.AssemblyLinearVelocity = steer * ESP.targetKitSpeed
		root.AssemblyAngularVelocity = Vector3.zero
		if ESP.targetKitStatusLbl then
			if ESP.targetKitArcMode then
				ESP.targetKitStatusLbl.Text = string.format(
					"%s · %s · %.0f studs · arc on · avoid %s · spd %.0f",
					phaseTag,
					tpl2.Name,
					dist,
					ESP.targetKitAvoid and "on" or "off",
					ESP.targetKitSpeed
				)
			else
				ESP.targetKitStatusLbl.Text = string.format(
					"Chasing %s · %.0f studs · avoid %s · speed %.0f",
					tpl2.Name,
					dist,
					ESP.targetKitAvoid and "on" or "off",
					ESP.targetKitSpeed
				)
			end
		end
	end)
	return true
end

function K.targetKitTeleportToPick()
	if not ESP.targetKitUserId then
		return false
	end
	local tpl = K.playerByUserId(ESP.targetKitUserId)
	local troot = tpl and tpl.Character and tpl.Character:FindFirstChild("HumanoidRootPart")
	local char = me.Character
	if not troot or not char then
		return false
	end
	local pivot = char:GetPivot()
	local dir = troot.Position - pivot.Position
	local flat = Vector3.new(dir.X, 0, dir.Z)
	local off
	if flat.Magnitude > 0.35 then
		off = flat.Unit * 5.5
	else
		off = troot.CFrame.RightVector * 5.5
	end
	local goalPos = troot.Position + Vector3.new(0, 2.2, 0) + off
	local look = (troot.Position + Vector3.new(0, 1.2, 0)) - goalPos
	if look.Magnitude < 0.15 then
		look = troot.CFrame.LookVector
	else
		look = look.Unit
	end
	pcall(function()
		char:PivotTo(CFrame.lookAt(goalPos, goalPos + look))
	end)
	local r = K.getRoot()
	if r then
		r.AssemblyLinearVelocity = Vector3.zero
		r.AssemblyAngularVelocity = Vector3.zero
	end
	if ESP.targetKitStatusLbl then
		ESP.targetKitStatusLbl.Text = "Teleported near " .. tpl.Name .. "."
	end
	return true
end

