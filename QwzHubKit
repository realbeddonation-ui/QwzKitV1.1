function K.populateAnimScanList()
	if not animScanScroll then
		return
	end
	local search = string.lower(animSearchText or "")
	for _, ch in animScanScroll:GetChildren() do
		if ch:IsA("TextButton") then
			ch:Destroy()
		end
	end
	for _, anim in ipairs(animScanResults) do
		local skipRow = false
		if search ~= "" then
			local hay = string.lower((anim.Name or "") .. " " .. (anim.AnimationId or ""))
			if string.find(hay, search, 1, true) == nil then
				skipRow = true
			end
		end
		if skipRow then
			-- next iteration (avoid `continue` — not valid in all Luau runtimes)
		else
		local row = Instance.new("TextButton")
		row.AutoButtonColor = false
		row.Size = UDim2.new(1, -6, 0, 30)
		row.BackgroundColor3 = Color3.fromRGB(32, 36, 52)
		row.TextXAlignment = Enum.TextXAlignment.Left
		row.Font = Enum.Font.Gotham
		row.TextSize = 11
		row.TextColor3 = Color3.new(1, 1, 1)
		row.BorderSizePixel = 0
		local shortId = anim.AnimationId
		if #shortId > 46 then
			shortId = string.sub(shortId, 1, 46) .. "…"
		end
		row.Text = "  " .. anim.Name .. "  |  " .. shortId
		row.Parent = animScanScroll
		K.roundCorners(row, 6)
		row.MouseButton1Click:Connect(function()
			animScanSelected = anim
			if animSelectionLabel then
				animSelectionLabel.Text = "Selected: "
					.. anim.Name
					.. "\n"
					.. anim:GetFullName()
			end
		end)
		end
	end
end

