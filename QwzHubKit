function K.stopCombatBoost()
	if combatBoostConn then
		combatBoostConn:Disconnect()
		combatBoostConn = nil
	end
	local h = K.getHumanoid()
	if h then
		h.WalkSpeed = savedWalkSpeed
	end
end

function K.startCombatBoost()
	K.stopCombatBoost()
	combatBoostConn = RunService.RenderStepped:Connect(function()
		if not combatBoostOn then
			return
		end
		local h = K.getHumanoid()
		if h and h.Health > 0 then
			local base = savedWalkSpeed
			if base <= 0 or base ~= base then
				base = 16
			end
			h.WalkSpeed = base * combatBoostMult
		end
	end)
end

function K.setCombatBoostRunning()
	if combatBoostOn then
		K.startCombatBoost()
	else
		K.stopCombatBoost()
	end
	if combatBoostLabel then
		combatBoostLabel.Text = string.format("Walk boost: %s (×%.2f saved)", combatBoostOn and "ON" or "OFF", combatBoostMult)
	end
end

function K.stopCombatResist()
	if combatResistConn then
		combatResistConn:Disconnect()
		combatResistConn = nil
	end
end

function K.startCombatResist()
	K.stopCombatResist()
	local stuckSince = nil
	local lastFlatPos = nil
	local desiredFlatPos = nil
	local noTpLastPos = nil
	combatResistConn = RunService.Heartbeat:Connect(function(dt)
		if not combatResistOn then
			stuckSince = nil
			lastFlatPos = nil
			noTpLastPos = nil
			return
		end
		local myRoot = K.getRoot()
		local h = K.getHumanoid()
		if not myRoot then
			stuckSince = nil
			lastFlatPos = nil
			desiredFlatPos = nil
			noTpLastPos = nil
			return
		end
		if h and h.Health <= 0 and not combatResistAllowDead then
			stuckSince = nil
			lastFlatPos = nil
			desiredFlatPos = nil
			noTpLastPos = nil
			return
		end
		if combatResistNoTpOn and noTpLastPos and combatResistNoTpDist > 0 then
			local jumped = (myRoot.Position - noTpLastPos).Magnitude
			if jumped > combatResistNoTpDist then
				local lv = myRoot.CFrame.LookVector
				myRoot.CFrame = CFrame.new(noTpLastPos, noTpLastPos + lv)
				myRoot.AssemblyLinearVelocity = Vector3.zero
				myRoot.AssemblyAngularVelocity = Vector3.zero
				desiredFlatPos = Vector3.new(noTpLastPos.X, 0, noTpLastPos.Z)
			end
		end
		if h then
			-- Keep upright; avoid "fall over" feel from forced physics state changes.
			h.PlatformStand = false
			h.AutoRotate = true
		end
		local cam = K.getCam()
		local flatDir = Vector3.zero
		local moveY = 0
		if cam then
			local look = cam.CFrame.LookVector
			local right = cam.CFrame.RightVector
			local flatLook = Vector3.new(look.X, 0, look.Z)
			local flatRight = Vector3.new(right.X, 0, right.Z)
			if flatLook.Magnitude > 0.001 then
				flatLook = flatLook.Unit
			end
			if flatRight.Magnitude > 0.001 then
				flatRight = flatRight.Unit
			end
			if UserInputService:IsKeyDown(Enum.KeyCode.W) or UserInputService:IsKeyDown(Enum.KeyCode.Up) then
				flatDir += flatLook
			end
			if UserInputService:IsKeyDown(Enum.KeyCode.S) or UserInputService:IsKeyDown(Enum.KeyCode.Down) then
				flatDir -= flatLook
			end
			if UserInputService:IsKeyDown(Enum.KeyCode.A) or UserInputService:IsKeyDown(Enum.KeyCode.Left) then
				flatDir -= flatRight
			end
			if UserInputService:IsKeyDown(Enum.KeyCode.D) or UserInputService:IsKeyDown(Enum.KeyCode.Right) then
				flatDir += flatRight
			end
			if flyOn and UserInputService:IsKeyDown(Enum.KeyCode.Space) then
				moveY += 1
			end
			if flyOn and (UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) or UserInputService:IsKeyDown(Enum.KeyCode.C)) then
				moveY -= 1
			end
		end
		if flatDir.Magnitude < 0.001 and h then
			local md = h.MoveDirection
			flatDir = Vector3.new(md.X, 0, md.Z)
		end
		if flatDir.Magnitude < 0.001 and math.abs(moveY) < 0.001 then
			stuckSince = nil
			lastFlatPos = Vector3.new(myRoot.Position.X, 0, myRoot.Position.Z)
			desiredFlatPos = nil
			if combatResistAntiMoveOn then
				local antiA = combatResistAntiMoveStrength * combatResistVelLerp
				local curV = myRoot.AssemblyLinearVelocity
				myRoot.AssemblyLinearVelocity = Vector3.new(curV.X * (1 - antiA), curV.Y, curV.Z * (1 - antiA))
			end
			noTpLastPos = myRoot.Position
			return
		end
		if flatDir.Magnitude > 0.001 then
			flatDir = flatDir.Unit
		end
		local pushSpeed = combatResistUseFlySpeed and flyOn and flySpeed or combatResistSpeed
		local stepDt = math.min(math.max(dt or 1 / 60, 1 / 240), 1 / 20)
		local desiredY = myRoot.AssemblyLinearVelocity.Y
		if flyOn and math.abs(moveY) > 0.001 then
			desiredY = moveY * pushSpeed
		end
		local curPosFlat = Vector3.new(myRoot.Position.X, 0, myRoot.Position.Z)
		if not desiredFlatPos then
			desiredFlatPos = curPosFlat
		end
		desiredFlatPos += flatDir * pushSpeed * stepDt
		local drift = desiredFlatPos - curPosFlat
		local maxDrift = pushSpeed * 0.45
		if drift.Magnitude > maxDrift and drift.Magnitude > 0 then
			drift = drift.Unit * maxDrift
		end
		local driftVel = drift * (combatResistDriftGain / math.max(stepDt, 1 / 240))
		local baseFlatVel = Vector3.new(flatDir.X * pushSpeed, 0, flatDir.Z * pushSpeed)
		local targetFlatVel = baseFlatVel + driftVel * combatResistCounterForce
		local maxFlatVel = pushSpeed * (1 + combatResistCounterForce)
		if targetFlatVel.Magnitude > maxFlatVel and targetFlatVel.Magnitude > 0 then
			targetFlatVel = targetFlatVel.Unit * maxFlatVel
		end
		local targetVel = Vector3.new(targetFlatVel.X, desiredY, targetFlatVel.Z)
		if combatResistAlwaysMove then
			if h then
				h:Move(Vector3.new(flatDir.X, 0, flatDir.Z), true)
			end
			local curV = myRoot.AssemblyLinearVelocity
			myRoot.AssemblyLinearVelocity = curV:Lerp(targetVel, combatResistVelLerp)
			noTpLastPos = myRoot.Position
			return
		end
		local now = os.clock()
		local flatPos = Vector3.new(myRoot.Position.X, 0, myRoot.Position.Z)
		local moved = true
		if lastFlatPos then
			moved = (flatPos - lastFlatPos).Magnitude > combatResistMoveEps
		end
		lastFlatPos = flatPos
		if moved then
			stuckSince = nil
			noTpLastPos = myRoot.Position
			return
		end
		if not stuckSince then
			stuckSince = now
			return
		end
		if now - stuckSince < combatResistStuckTime then
			noTpLastPos = myRoot.Position
			return
		end
		if h then
			h:Move(Vector3.new(flatDir.X, 0, flatDir.Z), true)
		end
		myRoot.AssemblyLinearVelocity = myRoot.AssemblyLinearVelocity:Lerp(targetVel, combatResistVelLerp)
		stuckSince = now - (combatResistStuckTime * 0.5)
		noTpLastPos = myRoot.Position
	end)
end

function K.setCombatResistRunning()
	if combatResistOn then
		K.startCombatResist()
	else
		K.stopCombatResist()
	end
	if combatResistLabel then
		combatResistLabel.Text = string.format(
			"Movement resistance: %s | speed %.0f anti-move %s(%.2f) force %.2f notp %s(%.1f)",
			combatResistOn and "ON" or "OFF",
			combatResistSpeed,
			combatResistAntiMoveOn and "on" or "off",
			combatResistAntiMoveStrength,
			combatResistCounterForce,
			combatResistNoTpOn and "on" or "off",
			combatResistNoTpDist
		)
	end
end

