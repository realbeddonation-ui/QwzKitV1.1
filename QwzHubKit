function CC.startFreecam()
	if CC.freecamOn then
		CC.stopFreecam()
		return
	end
	ESP.opFaceLockOn = false
	ESP.opCameraLockOn = false
	K.stopCameraLock()
	K.setOpCombatRunning()
	K.refreshFaceCameraLockUi()
	CC.stopOrbit()
	local cam = Workspace.CurrentCamera
	if not cam then
		return
	end
	CC.freecamSavedType = cam.CameraType
	CC.freecamSavedSubject = cam.CameraSubject
	cam.CameraType = Enum.CameraType.Scriptable
	cam.CameraSubject = nil
	CC.freecamOn = true
	local hum0 = K.getHumanoid()
	if hum0 then
		CC.freecamSavedWalkSpeed = hum0.WalkSpeed
		CC.freecamSavedJumpPower = hum0.JumpPower
		CC.freecamSavedAutoRotate = hum0.AutoRotate
		CC.freecamSavedPlatformStand = hum0.PlatformStand
		CC.freecamSavedJumpHeight = nil
		pcall(function()
			CC.freecamSavedJumpHeight = hum0.JumpHeight
		end)
		hum0.WalkSpeed = 0
		hum0.JumpPower = 0
		pcall(function()
			hum0.JumpHeight = 0
		end)
		hum0.AutoRotate = false
		hum0.PlatformStand = true
	end
	local yaw, pitch = 0, 0
	CC.freecamConn = RunService.RenderStepped:Connect(function(dt)
		if not CC.freecamOn then
			return
		end
		local c = Workspace.CurrentCamera
		if not c then
			return
		end
		local pos = c.CFrame.Position
		local md = UserInputService:GetMouseDelta()
		yaw -= md.X * 0.003
		pitch = math.clamp(pitch - md.Y * 0.003, -1.45, 1.45)
		local rot = CFrame.fromEulerAnglesYXZ(pitch, yaw, 0)
		local move = Vector3.zero
		if UserInputService:IsKeyDown(Enum.KeyCode.W) then
			move += rot.LookVector
		end
		if UserInputService:IsKeyDown(Enum.KeyCode.S) then
			move -= rot.LookVector
		end
		if UserInputService:IsKeyDown(Enum.KeyCode.D) then
			move += rot.RightVector
		end
		if UserInputService:IsKeyDown(Enum.KeyCode.A) then
			move -= rot.RightVector
		end
		if UserInputService:IsKeyDown(Enum.KeyCode.E) or UserInputService:IsKeyDown(Enum.KeyCode.Space) then
			move += Vector3.yAxis
		end
		if UserInputService:IsKeyDown(Enum.KeyCode.Q) or UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then
			move -= Vector3.yAxis
		end
		local spd = UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) and 95 or 42
		if move.Magnitude > 0.05 then
			pos += move.Unit * spd * dt
		end
		c.CFrame = CFrame.new(pos) * rot
	end)
	-- After normal RenderStepped (e.g. fly), zero HRP velocity so WASD/Space only move the camera.
	pcall(function()
		RunService:UnbindFromRenderStep(MENU_NAME .. "_FreecamFreeze")
	end)
	RunService:BindToRenderStep(MENU_NAME .. "_FreecamFreeze", 2147483645, function()
		if not CC.freecamOn then
			return
		end
		local root = K.getRoot()
		if root then
			root.AssemblyLinearVelocity = Vector3.zero
			root.AssemblyAngularVelocity = Vector3.zero
		end
	end)
end

