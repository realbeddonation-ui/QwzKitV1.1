	end
end

function CC.runAnimSlide()
	CC.stopAnimSlide()
	local char = me.Character
	local hum = char and char:FindFirstChildOfClass("Humanoid")
	local hrp = char and char:FindFirstChild("HumanoidRootPart")
	if not (hum and hrp) then
		return
	end
	local function slideOffsetFromBasis(rootPart)
		local look = rootPart.CFrame.LookVector
		local right = rootPart.CFrame.RightVector
		if CC.animSlideUseCamera then
			local cam = Workspace.CurrentCamera
			if cam then
				local camLook = Vector3.new(cam.CFrame.LookVector.X, 0, cam.CFrame.LookVector.Z)
				local camRight = Vector3.new(cam.CFrame.RightVector.X, 0, cam.CFrame.RightVector.Z)
				if camLook.Magnitude > 1e-4 then
					look = camLook.Unit
				end
				if camRight.Magnitude > 1e-4 then
					right = camRight.Unit
				end
			end
		end
		return look * (CC.animSlideFwd - CC.animSlideBack)
			+ right * (CC.animSlideRight - CC.animSlideLeft)
			+ Vector3.yAxis * (CC.animSlideUp - CC.animSlideDown)
	end
	local off = slideOffsetFromBasis(hrp)
	local dist = off.Magnitude
	if dist < 0.08 then
		warn("[Qwz kit] Anim slide: set at least one axis distance > 0.")
		return
	end
	local dur = CC.animSlideDuration
	local spd = CC.animSlideAnimSpeed
	local startCf = hrp.CFrame
	local ox, oy, oz = startCf:ToOrientation()
	local idStr = CC.animSlideId or ""
	local digits = string.match(idStr, "(%d+)")
	if digits and digits ~= "" then
		local anim = Instance.new("Animation")
		anim.AnimationId = "rbxassetid://" .. digits
		local animator = hum:FindFirstChildOfClass("Animator")
		if not animator then
			animator = Instance.new("Animator")
			animator.Parent = hum
		end
		local ok, tr = pcall(function()
			return animator:LoadAnimation(anim)
		end)
		if ok and tr then
			CC.animSlideTrack = tr
			tr.Looped = false
			tr:Play(0.1, 1, spd)
		end
	end
	local t0 = os.clock()
	local prevAlpha = 0
	CC.animSlideConn = RunService.RenderStepped:Connect(function()
		local hrp2 = K.getRoot()
		if not hrp2 then
			CC.stopAnimSlide()
			return
		end
		local t = (os.clock() - t0) * spd
		if t >= dur then
			t = dur
		end
		local alpha = t / dur
		if CC.animSlideEase then
			alpha = alpha * alpha * (3 - 2 * alpha)
		end
		local deltaAlpha = math.max(0, alpha - prevAlpha)
		prevAlpha = alpha
		local deltaDist = dist * deltaAlpha
		if deltaDist > 1e-5 then
			local stepOff = slideOffsetFromBasis(hrp2)
			if stepOff.Magnitude > 1e-5 then
				local pos = hrp2.Position + stepOff.Unit * deltaDist
				hrp2.CFrame = CFrame.new(pos) * CFrame.fromOrientation(ox, oy, oz)
			end
		end
		if t >= dur then
			CC.stopAnimSlide()
			return
		end
	end)
end

function CC.runSubtleFling()
	local r = K.getRoot()
	if not r or not r.Parent then
		warn("[Qwz kit] Fling: no local HumanoidRootPart.")
		return
	end
	CC.flingInProgress = true
	local ok, err = pcall(function()
		local base = (r.CFrame.LookVector + Vector3.new(0, 0.35, 0)).Unit
		local imp = CC.flingImpulse
		local steps = math.floor(CC.flingSteps)
		r.AssemblyAngularVelocity = Vector3.zero
		local mass = math.max(r.AssemblyMass, 1e-3)
		-- ApplyImpulse(I): deltaV = I / mass. Use I = mass * deltaV so each step adds ~imp/studs/s in that direction.
		for s = 1, steps do
			local jitter = Vector3.new((math.random() - 0.5) * 0.35, (math.random() - 0.5) * 0.25, (math.random() - 0.5) * 0.35)
			local dir = (base + jitter)
			if dir.Magnitude > 1e-4 then
				dir = dir.Unit
			else
				dir = base
			end
			local deltaV = dir * (imp / steps)
			local okApply, applyErr = pcall(function()
				r:ApplyImpulse(deltaV * mass)
			end)
			if not okApply then
				-- Fallback if ApplyImpulse fails in some environments
				r.AssemblyLinearVelocity = r.AssemblyLinearVelocity + deltaV
			end
			task.wait(0.02)
		end
	end)
	CC.flingInProgress = false
	if not ok then
		warn("[Qwz kit] Fling error:", err)
	end
end

function CC.stopFreecam()
	if CC.freecamConn then
		CC.freecamConn:Disconnect()
		CC.freecamConn = nil
	end
	local cam = Workspace.CurrentCamera
	if cam and CC.freecamSavedType then
		cam.CameraType = CC.freecamSavedType
		cam.CameraSubject = CC.freecamSavedSubject
	end
	CC.freecamSavedType = nil
	CC.freecamSavedSubject = nil
	CC.freecamOn = false
end

function CC.startFreecam()
	if CC.freecamOn then
		CC.stopFreecam()
		return
	end
	CC.stopOrbit()
	local cam = Workspace.CurrentCamera
	if not cam then
		return
	end
	CC.freecamSavedType = cam.CameraType
	CC.freecamSavedSubject = cam.CameraSubject
	cam.CameraType = Enum.CameraType.Scriptable
	cam.CameraSubject = nil
	CC.freecamOn = true
	local yaw, pitch = 0, 0
	CC.freecamConn = RunService.RenderStepped:Connect(function(dt)
		if not CC.freecamOn then
			return
		end
		local c = Workspace.CurrentCamera
		if not c then
			return
		end
		local pos = c.CFrame.Position
		local md = UserInputService:GetMouseDelta()
		yaw -= md.X * 0.003
		pitch = math.clamp(pitch - md.Y * 0.003, -1.45, 1.45)
		local rot = CFrame.fromEulerAnglesYXZ(pitch, yaw, 0)
		local move = Vector3.zero
		if UserInputService:IsKeyDown(Enum.KeyCode.W) then
			move += rot.LookVector
		end
		if UserInputService:IsKeyDown(Enum.KeyCode.S) then
			move -= rot.LookVector
		end
		if UserInputService:IsKeyDown(Enum.KeyCode.D) then
			move += rot.RightVector
		end
		if UserInputService:IsKeyDown(Enum.KeyCode.A) then
			move -= rot.RightVector
		end
		if UserInputService:IsKeyDown(Enum.KeyCode.E) or UserInputService:IsKeyDown(Enum.KeyCode.Space) then
			move += Vector3.yAxis
		end
		if UserInputService:IsKeyDown(Enum.KeyCode.Q) or UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then
			move -= Vector3.yAxis
		end
		local spd = UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) and 95 or 42
		if move.Magnitude > 0.05 then
			pos += move.Unit * spd * dt
		end
		c.CFrame = CFrame.new(pos) * rot
	end)
end

function CC.stopOrbit()
	if CC.orbitConn then
		CC.orbitConn:Disconnect()
		CC.orbitConn = nil
	end
	local cam = Workspace.CurrentCamera
	if cam and CC.orbitCamType then
		cam.CameraType = CC.orbitCamType
		cam.CameraSubject = CC.orbitCamSubject
	end
	CC.orbitCamType = nil
	CC.orbitCamSubject = nil
	CC.orbitOn = false
end

function CC.startOrbit()
	if CC.orbitOn then
		CC.stopOrbit()
		return
	end
	CC.stopFreecam()
	local cam = Workspace.CurrentCamera
	if not cam then
		return
	end
	CC.orbitCamType = cam.CameraType
	CC.orbitCamSubject = cam.CameraSubject
	cam.CameraType = Enum.CameraType.Scriptable
	cam.CameraSubject = nil
	CC.orbitOn = true
	CC.orbitAngle = 0
	CC.orbitConn = RunService.RenderStepped:Connect(function(dt)
		if not CC.orbitOn then
			return
		end
		local c = Workspace.CurrentCamera
		if not c then
			return
		end
		local sub = CC.getHrpForUserId(CC.orbitTargetUserId)
		local focus = sub and sub.Position or (me.Character and me.Character:GetPivot().Position)
		if not focus then
			return
		end
		CC.orbitAngle += dt * CC.orbitSpeed
		local r = CC.orbitRadius
		local h = CC.orbitHeight
		local offset = Vector3.new(math.cos(CC.orbitAngle) * r, h, math.sin(CC.orbitAngle) * r)
		local camPos = focus + offset
		c.CFrame = CFrame.lookAt(camPos, focus + Vector3.new(0, 1.2, 0))
	end)
end

function CC.cleanupOnRespawn()
	CC.stopAnimSlide()
	CC.stopFreecam()
	CC.stopOrbit()
end

