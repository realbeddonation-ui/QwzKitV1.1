function K.ensureBoxEsp(player, root)
	if not ESP.boxEsp or not root then
		local bx = ESP.boxAdorns[player]
		if bx then
			for _, ad in ipairs(bx) do
				pcall(function()
					ad:Destroy()
				end)
			end
			ESP.boxAdorns[player] = nil
		end
		return
	end
	local size = root.Size
	local list = ESP.boxAdorns[player]
	if not list then
		list = {}
		ESP.boxAdorns[player] = list
		local ad = Instance.new("BoxHandleAdornment")
		ad.Adornee = root
		ad.AlwaysOnTop = true
		ad.ZIndex = 5
		ad.Size = size
		ad.CFrame = CFrame.new()
		ad.Color3 = ESP.teamColor and player.Team and player.Team.TeamColor and player.Team.TeamColor.Color
			or COL.accent
		ad.Transparency = math.clamp(1 - ESP.chamsBrightness * 0.5, 0, 1)
		ad.Parent = root
		table.insert(list, ad)
	else
		for _, ad in ipairs(list) do
			if ad.Parent then
				ad.Adornee = root
				ad.Size = size
				ad.Color3 = ESP.teamColor and player.Team and player.Team.TeamColor and player.Team.TeamColor.Color
					or COL.accent
				ad.Transparency = math.clamp(1 - ESP.chamsBrightness * 0.5, 0, 1)
			end
		end
	end
end

function K.refreshEspPlayer(player)
	if player == me then
		return
	end

	-- hard target filter by UserId
	if ESP.targetOnly then
		if not ESP.targetUserId or player.UserId ~= ESP.targetUserId then
			K.destroyEspForPlayer(player)
			return
		end
	end

	local head = K.getHead(player)
	local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
	if not ESP.on or not head or not root then
		K.destroyEspForPlayer(player)
		return
	end

	local bb = ESP.billboards[player]
	local tl
	if not bb or not bb.Parent then
		bb, tl = K.makeBillboard(head, player)
		ESP.billboards[player] = bb
	else
		tl = bb:FindFirstChildWhichIsA("TextLabel")
		bb.Adornee = head
	end

	if tl then
		local hum = player.Character:FindFirstChildOfClass("Humanoid")
		local myR = K.getRoot()
		local dist = myR and (root.Position - myR.Position).Magnitude or 0
		local team = player.Team
		local parts = {}
		if ESP.names then
			table.insert(parts, player.Name)
		end
		if ESP.dist then
			table.insert(parts, string.format("[%.0fm]", dist))
		end
		if ESP.hp and hum then
			table.insert(parts, string.format("HP:%.0f", hum.Health))
		end
		tl.Text = table.concat(parts, "  ")
		if ESP.teamColor and team and team.TeamColor then
			tl.TextColor3 = team.TeamColor.Color
		else
			tl.TextColor3 = Color3.new(1, 1, 1)
		end
	end

	local hl = ESP.highlights[player]
	if not hl or not hl.Parent then
		hl = Instance.new("Highlight")
		hl.Name = "TesterESPHighlight"
		hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
		hl.FillTransparency = ESP.highlightFillTransparency
		hl.OutlineTransparency = 0
		hl.Parent = player.Character
		ESP.highlights[player] = hl
	end
	if player.Character and hl.Adornee ~= player.Character then
		hl.Adornee = player.Character
	end
	if ESP.teamColor and player.Team and player.Team.TeamColor then
		hl.FillColor = player.Team.TeamColor.Color
		hl.OutlineColor = player.Team.TeamColor.Color
	else
		hl.FillColor = COL.accent
		hl.OutlineColor = Color3.fromRGB(180, 235, 255)
	end

	K.ensureBoxEsp(player, root)

	if ESP.tracers then
		local cam = K.getCam()
		local g = K.ensureEspGui()
		local fr = ESP.tracerFrames[player]
		if not fr or not fr.Parent then
			fr = Instance.new("Frame")
			fr.Name = "Tracer_" .. player.Name
			fr.AnchorPoint = Vector2.new(0.5, 0.5)
			fr.BackgroundColor3 = ESP.teamColor and player.Team and player.Team.TeamColor and player.Team.TeamColor.Color or COL.accent
			fr.BorderSizePixel = 0
			fr.ZIndex = 1
			fr.Parent = g
			ESP.tracerFrames[player] = fr
		end
		local vp, inFront = cam:WorldToViewportPoint(head.Position)
		if inFront then
			local viewport = cam.ViewportSize
			local fromX, fromY
			if ESP.tracerOriginMode == "center" then
				fromX, fromY = viewport.X / 2, viewport.Y / 2
			elseif ESP.tracerOriginMode == "mouse" then
				local mx, my = UserInputService:GetMouseLocation()
				fromX, fromY = mx, my
			else
				fromX, fromY = viewport.X / 2, viewport.Y - 4
			end
			K.setTracerLine(fr, fromX, fromY, vp.X, vp.Y)
		else
			fr.Visible = false
		end
	else
		local fr = ESP.tracerFrames[player]
		if fr then
			fr.Visible = false
		end
	end
end

function K.espHeartbeat()
	if not ESP.on then
		return
	end

	if ESP.targetOnly then
		local target = K.getEspTargetPlayer()
		for _, plr in ipairs(Players:GetPlayers()) do
			if target and plr == target then
				K.refreshEspPlayer(plr)
			else
				K.destroyEspForPlayer(plr)
			end
		end
		return
	end

	for _, plr in ipairs(Players:GetPlayers()) do
		K.refreshEspPlayer(plr)
	end
end

K.setEspRunning = function()
	if ESP.updateConn then
		ESP.updateConn:Disconnect()
		ESP.updateConn = nil
	end
	if not ESP.on then
		K.clearAllEsp()
		if ESP.gui then
			ESP.gui:Destroy()
			ESP.gui = nil
		end
		return
	end
	K.ensureEspGui()
	ESP.updateConn = RunService.RenderStepped:Connect(K.espHeartbeat)
	for _, plr in ipairs(Players:GetPlayers()) do
		K.refreshEspPlayer(plr)
	end
end

function K.onPlayerRemoving(player)
	K.destroyEspForPlayer(player)
	if ESP.targetUserId and player.UserId == ESP.targetUserId then
		K.setEspTargetPlayer(nil)
	end
	if ESP.targetKitUserId and player.UserId == ESP.targetKitUserId then
		ESP.targetKitUserId = nil
		K.targetKitStopNav()
	end
	task.defer(K.refreshEspTargetList)
	task.defer(K.refreshTargetKitList)
end

