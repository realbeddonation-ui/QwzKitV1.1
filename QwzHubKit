-- ========= Macro logic (playback uses HRP XZ velocity + Humanoid:Move) =========
function K.stopMacroPlayback(idx)
	if Macro.moveConns[idx] then
		Macro.moveConns[idx]:Disconnect()
		Macro.moveConns[idx] = nil
	end
	if Macro.playConns[idx] then
		task.cancel(Macro.playConns[idx])
		Macro.playConns[idx] = nil
	end
	local r = K.getRoot()
	if r then
		local v = r.AssemblyLinearVelocity
		r.AssemblyLinearVelocity = Vector3.new(0, v.Y, 0)
	end
	local h = K.getHumanoid()
	if h then
		pcall(function()
			h:Move(Vector3.zero, false)
		end)
	end
end

function K.playMacro(idx)
	local mac = Macro.list[idx]
	if not mac or not mac.on or type(mac.inputs) ~= "table" or #mac.inputs == 0 then
		return
	end
	local function selectToolSlot(slotIdx)
		if not slotIdx or slotIdx < 1 then
			return
		end
		local char = me.Character
		local bp = me:FindFirstChildOfClass("Backpack")
		local tools = {}
		if char then
			for _, ch in ipairs(char:GetChildren()) do
				if ch:IsA("Tool") then
					table.insert(tools, ch)
				end
			end
		end
		if bp then
			for _, ch in ipairs(bp:GetChildren()) do
				if ch:IsA("Tool") then
					table.insert(tools, ch)
				end
			end
		end
		local tool = tools[slotIdx]
		if not tool then
			return
		end
		local h = K.getHumanoid()
		if h then
			pcall(function()
				h:EquipTool(tool)
			end)
		end
	end
	local function simulateNumberKey(slotIdx)
		local kp = (typeof(keypress) == "function") and keypress or nil
		local kr = (typeof(keyrelease) == "function") and keyrelease or nil
		local code
		if slotIdx == 1 then
			code = Enum.KeyCode.One
		elseif slotIdx == 2 then
			code = Enum.KeyCode.Two
		elseif slotIdx == 3 then
			code = Enum.KeyCode.Three
		elseif slotIdx == 4 then
			code = Enum.KeyCode.Four
		elseif slotIdx == 5 then
			code = Enum.KeyCode.Five
		elseif slotIdx == 6 then
			code = Enum.KeyCode.Six
		elseif slotIdx == 7 then
			code = Enum.KeyCode.Seven
		elseif slotIdx == 8 then
			code = Enum.KeyCode.Eight
		elseif slotIdx == 9 then
			code = Enum.KeyCode.Nine
		end
		if code then
			-- Prefer Roblox VirtualInputManager (reliably triggers InputBegan handlers in many exploit environments).
			local vim
			pcall(function()
				vim = game:GetService("VirtualInputManager")
			end)
			if vim and vim.SendKeyEvent then
				local ok = pcall(function()
					vim:SendKeyEvent(true, code, false, game)
					task.wait(0.08)
					vim:SendKeyEvent(false, code, false, game)
				end)
				if ok then
					return
				end
			end
			-- Next: exploit-provided key simulation, if available.
			if kp and kr then
				local ok = pcall(function()
					kp(code)
					task.wait(0.08)
					kr(code)
				end)
				if ok then
					return
				end
			end
		end
		-- Final fallback: try equipping the corresponding tool slot.
		selectToolSlot(slotIdx)
	end
	K.stopMacroPlayback(idx)
	Macro.playConns[idx] = task.spawn(function()
		local function stopMovePulse()
			if Macro.moveConns[idx] then
				Macro.moveConns[idx]:Disconnect()
				Macro.moveConns[idx] = nil
			end
			local h = K.getHumanoid()
			if h then
				pcall(function()
					h:Move(Vector3.zero, false)
				end)
			end
			local r = K.getRoot()
			if r then
				local v = r.AssemblyLinearVelocity
				r.AssemblyLinearVelocity = Vector3.new(0, v.Y, 0)
			end
		end
		local function startMovePulse(worldDir)
			stopMovePulse()
			if worldDir.Magnitude < 0.01 then
				return
			end
			local dir = Vector3.new(worldDir.X, 0, worldDir.Z)
			if dir.Magnitude < 0.01 then
				return
			end
			dir = dir.Unit
			Macro.moveConns[idx] = RunService.Heartbeat:Connect(function()
				local h = K.getHumanoid()
				local r = K.getRoot()
				if not h or not r or h.Health <= 0 then
					return
				end
				local v = r.AssemblyLinearVelocity
				r.AssemblyLinearVelocity = Vector3.new(dir.X * MACRO_MOVE_SPEED, v.Y, dir.Z * MACRO_MOVE_SPEED)
				pcall(function()
					h:Move(dir, false)
				end)
			end)
		end
		local t0 = os.clock()
		local inputs = mac.inputs
		local n = #inputs
		for i = 1, n do
			if not mac.on then
				break
			end
			local e = inputs[i]
			local when = t0 + e.t
			local slack = when - os.clock()
			if slack > 0 then
				task.wait(slack)
			end
			if not mac.on then
				break
			end
			local nextE = inputs[i + 1]
			local segEndClock = nextE and (t0 + nextE.t) or (os.clock() + 0.2)
			if e.action == "jump" then
				stopMovePulse()
				local h = K.getHumanoid()
				if h and h.Health > 0 then
					h:ChangeState(Enum.HumanoidStateType.Jumping)
				end
			elseif e.action == "movedir" then
				local dir = Vector3.new(e.x or 0, e.y or 0, e.z or 0)
				startMovePulse(dir)
				local hold = segEndClock - os.clock()
				if hold > 0 then
					task.wait(hold)
				end
			elseif e.action == "toolactivate" then
				stopMovePulse()
				local char = me.Character
				local tool = char and char:FindFirstChildOfClass("Tool")
				if tool and tool.Activated then
					pcall(function()
						tool.Activated:Fire()
					end)
				end
			elseif e.action == "tooldeactivate" then
				stopMovePulse()
				local char = me.Character
				local tool = char and char:FindFirstChildOfClass("Tool")
				if tool and tool.Deactivated then
					pcall(function()
						tool.Deactivated:Fire()
					end)
				end
			elseif e.action == "mclick" then
				stopMovePulse()
				local char = me.Character
				local tool = char and char:FindFirstChildOfClass("Tool")
				if tool and tool.Activated then
					pcall(function()
						tool.Activated:Fire()
					end)
				end
			elseif e.action == "key1" then
				simulateNumberKey(1)
			elseif e.action == "key2" then
				simulateNumberKey(2)
			elseif e.action == "key3" then
				simulateNumberKey(3)
			elseif e.action == "key4" then
				simulateNumberKey(4)
			elseif e.action == "key5" then
				simulateNumberKey(5)
			elseif e.action == "key6" then
				simulateNumberKey(6)
			elseif e.action == "key7" then
				simulateNumberKey(7)
			elseif e.action == "key8" then
				simulateNumberKey(8)
			elseif e.action == "key9" then
				simulateNumberKey(9)
			end
		end
		stopMovePulse()
	end)
end

