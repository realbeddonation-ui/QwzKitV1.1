	local function refreshProximityPromptList()
		local okScan, scanErr = pcall(function()
			for _, ch in ipairs(proximityPromptScroll:GetChildren()) do
				if ch:IsA("TextButton") then
					ch:Destroy()
				end
			end
			local list = {}
			for _, d in ipairs(game:GetDescendants()) do
				if d:IsA("ProximityPrompt") then
					table.insert(list, d)
				end
			end
			table.sort(list, function(a, b)
				return a:GetFullName() < b:GetFullName()
			end)
			proxCount.Text = string.format("Prompts: %d (click to trigger)", #list)
			for _, prompt in ipairs(list) do
				local b = Instance.new("TextButton")
				b.Size = UDim2.new(1, -8, 0, 26)
				b.BackgroundColor3 = Color3.fromRGB(32, 36, 52)
				b.TextColor3 = Color3.new(1, 1, 1)
				b.Font = Enum.Font.Gotham
				b.TextSize = 10
				b.TextXAlignment = Enum.TextXAlignment.Left
				b.AutoButtonColor = false
				b.Active = true
				b.ZIndex = 2
				b.Parent = proximityPromptScroll
				K.roundCorners(b, 5)
				local objName = prompt.ObjectText
				if objName == "" then
					local p = prompt.Parent
					objName = p and p.Name or "?"
				end
				local act = prompt.ActionText
				if act == "" then
					act = "Interact"
				end
				b.Text = string.format("%s — %s  [%s]", objName, act, prompt:GetFullName())
				b.MouseButton1Click:Connect(function()
					K.triggerProximityPrompt(prompt)
				end)
			end
			proximityPromptScroll.CanvasSize = UDim2.new(0, 0, 0, proxListLayout.AbsoluteContentSize.Y + 8)
		end)
		if not okScan then
			warn("[Qwz kit] Proximity prompt scan failed:", scanErr)
			proxCount.Text = "Prompts: (scan failed — see Output)"
		end
	end

	proxListLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
		proximityPromptScroll.CanvasSize = UDim2.new(0, 0, 0, proxListLayout.AbsoluteContentSize.Y + 8)
	end)

	proxRefresh.MouseButton1Click:Connect(function()
		task.defer(refreshProximityPromptList)
	end)
