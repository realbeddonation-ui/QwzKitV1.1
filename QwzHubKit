function K.menuFillCustomizeTab(pageCustom, menuRefs)
	local numRows = {}

	local function ensureScale()
		if menuRefs.scaleObj and menuRefs.scaleObj.Parent then
			return menuRefs.scaleObj
		end
		local s = Instance.new("UIScale")
		s.Scale = ESP.menuScale
		s.Parent = panel
		menuRefs.scaleObj = s
		return s
	end

	local function makeNumRow(title, get, set, step, fmt)
		local row = Instance.new("Frame")
		row.BackgroundTransparency = 1
		row.Size = UDim2.new(1, 0, 0, 30)
		row.Parent = pageCustom
		local lay = Instance.new("UIListLayout", row)
		lay.FillDirection = Enum.FillDirection.Horizontal
		lay.HorizontalAlignment = Enum.HorizontalAlignment.Right
		lay.Padding = UDim.new(0, 6)
		local lbl = Instance.new("TextLabel")
		lbl.BackgroundTransparency = 1
		lbl.Size = UDim2.new(1, -90, 1, 0)
		lbl.Font = Enum.Font.Gotham
		lbl.TextSize = 11
		lbl.TextXAlignment = Enum.TextXAlignment.Left
		lbl.TextColor3 = Color3.fromRGB(200, 205, 220)
		lbl.Parent = row
		local down = Instance.new("TextButton")
		down.Size = UDim2.fromOffset(28, 24)
		down.Text = "-"
		down.Parent = row
		K.roundCorners(down, 4)
		local up = Instance.new("TextButton")
		up.Size = UDim2.fromOffset(28, 24)
		up.Text = "+"
		up.Parent = row
		K.roundCorners(up, 4)
		local rec = {}
		rec.sync = function()
			lbl.Text = title .. ": " .. string.format(fmt or "%.2f", get())
		end
		down.Activated:Connect(function()
			set(get() - step)
			rec.sync()
		end)
		up.Activated:Connect(function()
			set(get() + step)
			rec.sync()
		end)
		rec.sync()
		table.insert(numRows, rec)
		return rec
	end

	local function applyMenuVisuals()
		if menuRefs.panel then
			menuRefs.panel.Size = UDim2.fromOffset(ESP.menuWidth, ESP.menuHeight)
			menuRefs.panel.BackgroundTransparency = ESP.menuBgAlpha
		end
		if menuRefs.panelCorner then
			menuRefs.panelCorner.CornerRadius = UDim.new(0, ESP.menuCorner)
		end
		if menuRefs.topBar then
			menuRefs.topBar.BackgroundTransparency = ESP.menuTopAlpha
		end
		if menuRefs.tabBar then
			menuRefs.tabBar.BackgroundTransparency = ESP.menuTabAlpha
		end
		if menuRefs.borderStroke then
			menuRefs.borderStroke.Thickness = ESP.menuBorderThickness
			menuRefs.borderStroke.Transparency = ESP.menuBorderAlpha
		end
		if menuRefs.subtitle then
			menuRefs.subtitle.Visible = ESP.menuShowSubtitle
		end
		if menuRefs.closeBtn then
			menuRefs.closeBtn.Visible = ESP.menuShowClose
		end
		if menuRefs.tabScroll then
			menuRefs.tabScroll.ScrollBarThickness = ESP.menuHideTabScrollbar and 0 or 3
		end
		if menuRefs.tabButtons then
			for _, b in ipairs(menuRefs.tabButtons) do
				b.TextSize = ESP.menuTabTextSize
			end
		end
		if menuRefs.screen then
			menuRefs.screen.DisplayOrder = ESP.menuAlwaysTop and 50 or 0
		end
		ensureScale().Scale = ESP.menuScale
		menuRefs.dragLocked = ESP.menuDragLock
	end

	local function applyRainbow()
		if ESP.menuRainbowBorderOn then
			if ESP.menuRainbowConn then
				ESP.menuRainbowConn:Disconnect()
			end
			local stroke = menuRefs.borderStroke
			ESP.menuRainbowConn = RunService.RenderStepped:Connect(function()
				if not stroke or not stroke.Parent then
					return
				end
				local t = os.clock() * 0.35
				stroke.Color = Color3.fromHSV(t % 1, 0.7, 1)
			end)
		else
			if ESP.menuRainbowConn then
				ESP.menuRainbowConn:Disconnect()
				ESP.menuRainbowConn = nil
			end
			if menuRefs.borderStroke then
				menuRefs.borderStroke.Color = Color3.fromRGB(70, 140, 255)
			end
		end
	end

	K.addSectionLabel(pageCustom, "SIZE AND LAYOUT")
	makeNumRow("Scale", function()
		return ESP.menuScale
	end, function(v)
		ESP.menuScale = v
		applyMenuVisuals()
	end, 0.05, "%.2f")
	makeNumRow("Width", function()
		return ESP.menuWidth
	end, function(v)
		ESP.menuWidth = math.floor(v + 0.5)
		applyMenuVisuals()
	end, 10, "%.0f")
	makeNumRow("Height", function()
		return ESP.menuHeight
	end, function(v)
		ESP.menuHeight = math.floor(v + 0.5)
		applyMenuVisuals()
	end, 10, "%.0f")
	makeNumRow("Corner radius", function()
		return ESP.menuCorner
	end, function(v)
		ESP.menuCorner = math.floor(v + 0.5)
		applyMenuVisuals()
	end, 1, "%.0f")

	K.addSectionLabel(pageCustom, "VISUAL TUNING")
	makeNumRow("Background alpha", function()
		return ESP.menuBgAlpha
	end, function(v)
		ESP.menuBgAlpha = v
		applyMenuVisuals()
	end, 0.05, "%.2f")
	makeNumRow("Top bar alpha", function()
		return ESP.menuTopAlpha
	end, function(v)
		ESP.menuTopAlpha = v
		applyMenuVisuals()
	end, 0.05, "%.2f")
	makeNumRow("Tab bar alpha", function()
		return ESP.menuTabAlpha
	end, function(v)
		ESP.menuTabAlpha = v
		applyMenuVisuals()
	end, 0.05, "%.2f")
	makeNumRow("Border thickness", function()
		return ESP.menuBorderThickness
	end, function(v)
		ESP.menuBorderThickness = v
		applyMenuVisuals()
	end, 0.1, "%.1f")
	makeNumRow("Border alpha", function()
		return ESP.menuBorderAlpha
	end, function(v)
		ESP.menuBorderAlpha = v
		applyMenuVisuals()
	end, 0.05, "%.2f")
	makeNumRow("Tab text size", function()
		return ESP.menuTabTextSize
	end, function(v)
		ESP.menuTabTextSize = math.floor(v + 0.5)
		applyMenuVisuals()
	end, 1, "%.0f")

	K.addSectionLabel(pageCustom, "TOGGLES")
	local dragBtn = K.makeToggleButton(pageCustom, "Drag lock: off", function(btn)
		ESP.menuDragLock = not ESP.menuDragLock
		applyMenuVisuals()
		btn.Text = ESP.menuDragLock and "Drag lock: on" or "Drag lock: off"
	end)
	dragBtn.Text = ESP.menuDragLock and "Drag lock: on" or "Drag lock: off"
	local subtitleBtn = K.makeToggleButton(pageCustom, "Show subtitle: on", function(btn)
		ESP.menuShowSubtitle = not ESP.menuShowSubtitle
		applyMenuVisuals()
		btn.Text = ESP.menuShowSubtitle and "Show subtitle: on" or "Show subtitle: off"
	end)
	subtitleBtn.Text = ESP.menuShowSubtitle and "Show subtitle: on" or "Show subtitle: off"
	local closeBtnTog = K.makeToggleButton(pageCustom, "Show close button: on", function(btn)
		ESP.menuShowClose = not ESP.menuShowClose
		applyMenuVisuals()
		btn.Text = ESP.menuShowClose and "Show close button: on" or "Show close button: off"
	end)
	closeBtnTog.Text = ESP.menuShowClose and "Show close button: on" or "Show close button: off"
	local hideScrollBtn = K.makeToggleButton(pageCustom, "Hide tab scrollbar: off", function(btn)
		ESP.menuHideTabScrollbar = not ESP.menuHideTabScrollbar
		applyMenuVisuals()
		btn.Text = ESP.menuHideTabScrollbar and "Hide tab scrollbar: on" or "Hide tab scrollbar: off"
	end)
	hideScrollBtn.Text = ESP.menuHideTabScrollbar and "Hide tab scrollbar: on" or "Hide tab scrollbar: off"
	local topBtn = K.makeToggleButton(pageCustom, "Menu always on top: off", function(btn)
		ESP.menuAlwaysTop = not ESP.menuAlwaysTop
		applyMenuVisuals()
		btn.Text = ESP.menuAlwaysTop and "Menu always on top: on" or "Menu always on top: off"
	end)
	topBtn.Text = ESP.menuAlwaysTop and "Menu always on top: on" or "Menu always on top: off"

	local rainbowBtn = K.makeToggleButton(pageCustom, "Rainbow border: off", function(btn)
		ESP.menuRainbowBorderOn = not ESP.menuRainbowBorderOn
		btn.Text = ESP.menuRainbowBorderOn and "Rainbow border: on" or "Rainbow border: off"
		applyRainbow()
	end)
	rainbowBtn.Text = ESP.menuRainbowBorderOn and "Rainbow border: on" or "Rainbow border: off"
	applyRainbow()

	K.addSectionLabel(pageCustom, "QUICK ACTIONS")
	local centerBtn = K.makeToggleButton(pageCustom, "Center menu on screen", function()
		local inset = GuiService:GetGuiInset()
		panel.Position = UDim2.new(0, 12 + inset.X, 0.5, -panel.AbsoluteSize.Y / 2)
	end)
	centerBtn.BackgroundColor3 = Color3.fromRGB(52, 66, 96)
	local resetPosBtn = K.makeToggleButton(pageCustom, "Reset only position", function()
		local inset = GuiService:GetGuiInset()
		panel.Position = UDim2.new(0, 12 + inset.X, 0.5, -panel.AbsoluteSize.Y / 2)
	end)
	resetPosBtn.BackgroundColor3 = Color3.fromRGB(52, 66, 96)
	local mobileQuickBtn = K.makeToggleButton(pageCustom, "Mobile quick buttons: on", function(btn)
		ESP.mobileQuickButtonsOn = not ESP.mobileQuickButtonsOn
		btn.Text = ESP.mobileQuickButtonsOn and "Mobile quick buttons: on" or "Mobile quick buttons: off"
		if mobileQuickFrame and mobileQuickFrame.Parent then
			mobileQuickFrame.Visible = ESP.mobileQuickButtonsOn
		end
	end)
	mobileQuickBtn.Text = ESP.mobileQuickButtonsOn and "Mobile quick buttons: on" or "Mobile quick buttons: off"
	mobileQuickBtn.BackgroundColor3 = Color3.fromRGB(52, 66, 96)

	local resetBtn = K.makeToggleButton(pageCustom, "Reset all customization settings", function()
		ESP.menuScale = 1
		ESP.menuBgAlpha = 0
		ESP.menuDragLock = false
		ESP.menuRainbowBorderOn = false
		ESP.menuWidth = 420
		ESP.menuHeight = 560
		ESP.menuCorner = 14
		ESP.menuTopAlpha = 0.15
		ESP.menuTabAlpha = 0.4
		ESP.menuBorderThickness = 1.2
		ESP.menuBorderAlpha = 0.35
		ESP.menuShowSubtitle = true
		ESP.menuShowClose = true
		ESP.menuTabTextSize = 10
		ESP.menuHideTabScrollbar = false
		ESP.menuAlwaysTop = false
		ESP.mobileQuickButtonsOn = true
		applyMenuVisuals()
		applyRainbow()
		local inset = GuiService:GetGuiInset()
		panel.Position = UDim2.new(0, 12 + inset.X, 0.5, -panel.AbsoluteSize.Y / 2)
		dragBtn.Text = "Drag lock: off"
		subtitleBtn.Text = "Show subtitle: on"
		closeBtnTog.Text = "Show close button: on"
		hideScrollBtn.Text = "Hide tab scrollbar: off"
		topBtn.Text = "Menu always on top: off"
		rainbowBtn.Text = "Rainbow border: off"
		mobileQuickBtn.Text = "Mobile quick buttons: on"
		if mobileQuickFrame and mobileQuickFrame.Parent then
			mobileQuickFrame.Visible = true
		end
		for _, r in ipairs(numRows) do
			r.sync()
		end
	end)
	resetBtn.BackgroundColor3 = Color3.fromRGB(70, 65, 45)

	applyMenuVisuals()
